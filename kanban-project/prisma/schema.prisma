  natureza     String?  @db.VarChar(10)   // debit / credit
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  produtosFinanceiros ProdutoFinanceiro[]
}

model CarteiraRecebimento {
  id              Int            @id @default(autoincrement())
  nome            String         @db.VarChar(100)
  tipo            String?        @db.VarChar(30)   // bank_account/pix/card_gateway/boleto/cash/international_transfer/wallet/payment_link
