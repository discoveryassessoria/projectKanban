  prioridade    String    @default("normal") @db.VarChar(20)

  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  cancelledAt   DateTime?

  steps         WorkflowStep[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([documentoId])
  @@index([status])
  @@index([faseCode])
}

model WorkflowStep {
  id              Int       @id @default(autoincrement())
  workflowId      Int
  workflow        Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  ordem           Int
  stepKey         String    @db.VarChar(60)
  title           String    @db.VarChar(200)
  description     String?   @db.Text
  status          String    @default("nao_iniciada") @db.VarChar(30)
  weight          Int       @default(0)

  ownerKey        String?   @db.VarChar(60)
  assigneeId      Int?
  assignee        Usuario?  @relation("WorkflowStepAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  startedAt       DateTime?
  dueAt           DateTime?
  completedAt     DateTime?
  completedById   Int?
  completedBy     Usuario?  @relation("WorkflowStepCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)

  motivoBloqueio  String?   @db.VarChar(300)
  notes           String?   @db.Text
  slaDays         Int       @default(1)

  trackingCode      String? @db.VarChar(120)
  externalProtocol  String? @db.VarChar(120)
  requestChannel    String? @db.VarChar(60)
  reviewResult      String? @db.VarChar(60)
  validationResult  String? @db.VarChar(60)

  externalEntityName  String?  @db.VarChar(200)
  costPaid            Decimal? @db.Decimal(10, 2)
  paymentMethod       String?  @db.VarChar(30)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  documentMedium     String?     @db.VarChar(20)
  physicalLocation   String?     @db.VarChar(200)

  reviewChecklist    Json?
  stepObservation    String?     @db.Text

  legalOpinion       String?     @db.Text

  // Regra de conclusão do passo (motor). null = usa o padrão por stepKey.
  completionPolicy   String?     @db.VarChar(40)

  @@index([workflowId])
  @@index([status])
  @@index([assigneeId])
}

// ============================================================
// ANÁLISE DOCUMENTAL (fase de PROCESSO — compara árvore × documentos)
// ============================================================
model AnaliseDocumental {
  id                   Int       @id @default(autoincrement())
  processoId           Int       @unique
  processo             Processo  @relation(fields: [processoId], references: [id], onDelete: Cascade)

  // "pendente" | "em_andamento" | "concluida"
  status               String    @default("pendente") @db.VarChar(20)
  // "comparacao_ia" | "revisao_humana" | "decisao_juridica"
  currentStep          String    @default("comparacao_ia") @db.VarChar(30)

  // KPIs da tela
  totalDocumentos      Int       @default(0)
  documentosAnalisados Int       @default(0)
  camposComparados     Int       @default(0)
  resumoIA             String?   @db.Text

  // null (ainda não) | "com_retificacao" | "sem_retificacao"
  decisaoJuridica      String?   @db.VarChar(20)
  requerRetificacao    Boolean   @default(false)

  startedAt            DateTime?
  completedAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  divergencias         Divergencia[]

  @@index([processoId])
  @@index([status])
}

model Divergencia {
  id                  Int               @id @default(autoincrement())
  analiseId           Int
  analise             AnaliseDocumental @relation(fields: [analiseId], references: [id], onDelete: Cascade)

  // Snapshots (auto-contido — não quebra se a pessoa/doc mudar depois)
  pessoaId            Int?
  pessoaNome          String    @db.VarChar(200)
  geracao             Int?
  linhaReta           Boolean   @default(true)
  documentoId         Int?
  documentoTitulo     String    @db.VarChar(200)
  dataDocumento       String?   @db.VarChar(20)

  // O que divergiu
  campo               String    @db.VarChar(60)   // "pai", "sobrenome", "cidade_nascimento"...
  campoLabel          String    @db.VarChar(120)  // "Nome do pai"
  valorArvore         String?   @db.VarChar(300)
  valorDocumento      String?   @db.VarChar(300)

  // Classificação da comparação
  tipo                String    @db.VarChar(40)   // "nome" | "filiacao" | "localidade"...
  severidade          String    @db.VarChar(10)   // "baixa" | "media" | "critica"
  sugestaoIA          String?   @db.VarChar(300)
  motivoIA            String?   @db.Text
  impacto             String?   @db.VarChar(300)
  requerRetificacaoIA Boolean   @default(false)

  // Decisão humana: "pendente" | "aceita" | "ressalva" | "ignorada" | "retificacao" | "apoio_solicitado"
  status              String    @default("pendente") @db.VarChar(20)
  decididoPorId       Int?
  decididoEm          DateTime?
  notas               String?   @db.Text

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([analiseId])
  @@index([status])
  @@index([severidade])
}

model PastaTraducao {
  id              Int       @id @default(autoincrement())
  processoId      Int       @unique
  processo        Processo  @relation(fields: [processoId], references: [id], onDelete: Cascade)
  status          String    @default("em_andamento")   // em_andamento | concluida
  currentStep     String    @default("montar_pasta_traducao")
  sourceLanguage  String    @default("Português")
  targetLanguage  String    @default("Italiano")
  translatorName  String?
  translatorEmail String?
  cost            String?
  expectedDate    DateTime?
  sentAt          DateTime?
  receivedAt      DateTime?
  validatedAt     DateTime?
  validatedById   Int?      // snapshot, sem FK (mesmo padrão da Análise)
  workflow        Json?     // 6 passos TR_STEPS: [{id,title,status,doneAt}]
  documentos      PastaTraducaoDocumento[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model PastaTraducaoDocumento {
  id                 Int            @id @default(autoincrement())
  pastaTraducaoId    Int
  pastaTraducao      PastaTraducao  @relation(fields: [pastaTraducaoId], references: [id], onDelete: Cascade)
  documentoId        Int            // snapshot, sem FK
  pessoaNome         String         @default("")
  documentoTitulo    String         @default("")
  origem             String         @default("")
  status             String         @default("pendente")  // pendente|incluido_na_pasta|enviado|traducao_recebida|conferido|validado|correcao_solicitada|bloqueado
  translatedFile     String?
  conferenceResult   String?
  validationDecision String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([pastaTraducaoId])
}

model PastaApostilamento {
  id                 Int       @id @default(autoincrement())
  processoId         Int       @unique
  processo           Processo  @relation(fields: [processoId], references: [id], onDelete: Cascade)
  status             String    @default("em_andamento")   // em_andamento | concluida
  currentStep        String    @default("montar_pasta_apostilamento")
  destinationCountry String?
  apostilleType      String?
  authorityName      String?
  attendant          String?
  cost               String?
  trackingCode       String?
  expectedDate       DateTime?
  sentAt             DateTime?
  receivedAt         DateTime?
  validatedAt        DateTime?
  validatedById      Int?
  workflow           Json?     // 6 passos AP_STEPS
  documentos         PastaApostilamentoDocumento[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model PastaApostilamentoDocumento {
  id                   Int                 @id @default(autoincrement())
  pastaApostilamentoId Int
  pastaApostilamento   PastaApostilamento  @relation(fields: [pastaApostilamentoId], references: [id], onDelete: Cascade)
  documentoId          Int                 // snapshot, sem FK
  pessoaNome           String              @default("")
  documentoTitulo      String              @default("")
  origem               String              @default("")
  status               String              @default("pendente")  // pendente|incluido_na_pasta|enviado|apostila_recebida|conferido|validado|correcao_solicitada|bloqueado
  apostilledFile       String?
  apostilleNumber      String?
  apostilleDate        String?   // "dd/mm/aaaa" (por documento)
  issuingAuthority     String?
  conferenceResult     String?
  validationDecision   String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([pastaApostilamentoId])
}

model FaseFinal {
  id          Int      @id @default(autoincrement())
  processoId  Int
  processo    Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)
  faseKey     String   // waitingProtocol | protocolado | finalizado
  status      String   @default("em_andamento") // em_andamento | concluida
  currentStep String
  workflow    Json?    // etapas da fase (3 passos)
  data        Json?    // { fnNum, fnData, fnOrgao, fnCanal, fnF1, lastDecision, ... }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([processoId, faseKey])
}

model RetificacaoPacote {
  id            Int      @id @default(autoincrement())
  processoId    Int
  processo      Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)
  num           String   // PR-001
  tipo          String   // judicial | administrativa
  status        String   @default("em_preparacao") // em_preparacao|protocolado|em_exigencia|decisao_recebida|validado|bloqueado
  currentStep   String   @default("definir_estrategia")
  motivo        String?
  prioridade    String?  @default("Média")
  proxAcao      String?
  // Judicial
  processoNum   String?
  tribunal      String?
  vara          String?
  comarca       String?
  advogado      String?
  oab           String?
  statusProc    String?
  // Administrativa
  cartorio      String?
  canal         String?
  protocolo     String?
  dataProtocolo String?
  atendente     String?
  prazo         String?
  statusAdm     String?
  // Variáveis (Json)
  workflow      Json?    // 6 passos RET_STEPS
  divergenceIds Json?    // divergências vinculadas (snapshot)
  affectedDocIds Json?   // documentos afetados (snapshot)
  movements     Json?    // [{data,tipo,desc,resp,prox}]
  attachments   Json?    // [{nome,cat,data,por,obs}]
  validacao     Json?    // {ressalva, obs, ...}
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([processoId])
}

model EmissaoRetificada {
  id                Int      @id @default(autoincrement())
  processoId        Int
  processo          Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)
  documentoId       Int      // snapshot, sem FK forte (igual Divergencia)
  pessoaNome        String
  pessoaGen         String?
  pessoaPapel       String?
  documentoTitulo   String
  correcaoCampo     String?
  correcaoOld       String?
  correcaoNovo      String?
  status            String   @default("pendente_averbacao")
  nextAction        String   @default("Enviar pedido de averbação ao cartório")
  workflow          Json     // 6 etapas RE_STEPS + blocos averbacao/solicitation/receipt/conference/validation
  retifiedValidated Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([processoId, documentoId])
  @@index([processoId])
}

model Banco {
