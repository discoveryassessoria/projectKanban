  name         String   @db.VarChar(200)
  papel        String?  @db.VarChar(120)   // vira FK p/ Papéis quando existir
  modoCalculo  String   @default("percentage") @db.VarChar(20)
  percent      Decimal? @db.Decimal(5, 2)
  valorFixo    Decimal? @db.Decimal(12, 2)
  momento      String   @default("first_payment_received") @db.VarChar(30)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

// ── Regras de Desconto (fin_disc) ──
model RegraDesconto {
  id                     Int      @id @default(autoincrement())
  name                   String   @db.VarChar(200)
  maxPercentSemAprovacao Decimal? @db.Decimal(5, 2)
  maxValorSemAprovacao   Decimal? @db.Decimal(12, 2)
