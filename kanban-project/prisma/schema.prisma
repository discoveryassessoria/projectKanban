  parcelas       Int                  @default(1)
  diaVencimento  Int?
  aplicarTaxas   Boolean              @default(false)
  ativo          Boolean              @default(true)
  criadoEm       DateTime             @default(now())
  atualizadoEm   DateTime             @updatedAt

  @@index([carteiraId])
}

// ── Honorários (fin_honorariums) ──
model Honorario {
  id              Int      @id @default(autoincrement())
  code            String   @db.VarChar(40)
  name            String   @db.VarChar(200)
  tipo            String   @default("main") @db.VarChar(30)
  servico         String?  @db.VarChar(200)   // vira FK p/ Serviços quando existir
  moeda           Moeda    @default(EUR)
  valorPadrao     Decimal? @db.Decimal(12, 2)
  momentoCobranca String   @default("contract_signed") @db.VarChar(30)
  ativo           Boolean  @default(true)
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt
}

// ── Regras de Comissão (fin_comm) ──
model RegraComissao {
