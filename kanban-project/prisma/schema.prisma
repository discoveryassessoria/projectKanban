  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model Imposto {
  id           Int       @id @default(autoincrement())
  codigo       String?   @db.VarChar(20)
  nome         String    @db.VarChar(100)
  tipo         String?   @db.VarChar(20)   // municipal/federal/state/international/service_tax/withholding/other
  modoCalculo  String?   @db.VarChar(20)   // percentage / fixed
  percentual   Decimal?  @db.Decimal(7, 4)
  valorFixo    Decimal?  @db.Decimal(12, 2)
  aplicaA      String?   @db.VarChar(20)   // revenue / cost / service
