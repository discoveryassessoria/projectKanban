  isDefault       Boolean        @default(false)
  ativo           Boolean        @default(true)
  criadoEm        DateTime       @default(now())
  atualizadoEm    DateTime       @updatedAt
  condicoesPagamento CondicaoPagamento[]

  @@index([contaBancariaId])
}

model ProdutoFinanceiro {
  id                Int                  @id @default(autoincrement())
  codigo            String               @db.VarChar(30)
  nome              String               @db.VarChar(200)
  especie           String?              @db.VarChar(20)   // kind
  tipoFinanceiro    String?              @db.VarChar(20)   // financialType
  categoriaId       Int?
  categoria         CategoriaFinanceira? @relation(fields: [categoriaId], references: [id])
  planoContaId      Int?
  planoConta        PlanoConta?          @relation(fields: [planoContaId], references: [id])
  moedaPadrao       Moeda                @default(BRL)
  valorPadrao       Decimal?             @db.Decimal(12, 2)
  aplicaA           String?              @db.VarChar(20)   // appliesTo
  cobravelDoCliente Boolean              @default(false)
  ativo             Boolean              @default(true)
  criadoEm          DateTime             @default(now())
  atualizadoEm      DateTime             @updatedAt
  naturezaFinanceira String?  @default("revenue") @db.VarChar(20)
  custoInterno       Boolean  @default(false)
  repasse            Boolean  @default(false)
  reembolsavel       Boolean  @default(false)
  servicos ServicoProduto[] @relation("ServicoProdutoItens")

  @@index([categoriaId])
  @@index([planoContaId])
}

// ── Tabela de Valores (fin_values) ──
model TabelaValor {
  id               Int         @id @default(autoincrement())
  name             String      @db.VarChar(200)
  // soltos por ora (viram FK quando o motor/serviços existirem)
  processoTipoId   String?     @db.VarChar(60)
  faseKey          String?     @db.VarChar(60)
  produtoServicoId String?     @db.VarChar(60)
  // FK real
  fornecedorId     Int?
  fornecedor       Fornecedor? @relation(fields: [fornecedorId], references: [id])
  moeda            Moeda       @default(EUR)
  valor            Decimal     @default(0) @db.Decimal(12, 2)
  modoCalculo      String      @default("fixed") @db.VarChar(20)
  condicao         String?     @db.VarChar(200)
  vigenciaInicio   String?     @db.VarChar(10)
  vigenciaFim      String?     @db.VarChar(10)
  arquivado        Boolean     @default(false)
  criadoEm         DateTime    @default(now())
  atualizadoEm     DateTime    @updatedAt

  @@index([fornecedorId])
}

// ── Condições de Pagamento (fin_paycond) ──
model CondicaoPagamento {
  id             Int                  @id @default(autoincrement())
  name           String               @db.VarChar(200)
  moeda          Moeda                @default(BRL)
  formaPagamento FormaPagamento?
