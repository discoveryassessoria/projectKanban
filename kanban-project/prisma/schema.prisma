model ModalidadePais {
  id            Int      @id @default(autoincrement())
  countryKey    String   @db.VarChar(40)
  modalityKey   String   @db.VarChar(40)
  modalityLabel String   @db.VarChar(80)
  codeSuffix    String?  @db.VarChar(20)
  ordem         Int      @default(0)
  ativo         Boolean  @default(true)
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt
