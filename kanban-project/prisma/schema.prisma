generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("PRISMA_DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Usuario {
  id                 Int                @id @default(autoincrement())
  nome               String             @db.VarChar(100)
  email              String             @unique @db.VarChar(100)
  senha              String             @db.VarChar(255)
  tipo               String             @db.VarChar(20)
  perfilId           Int?
  permissoesCustom   Json?
  eventosFinanceiros EventoFinanceiro[] @relation("EventoFinanceiroUsuario")
  logs               LogAuditoria[]
  mensagens          Mensagem[]
  recibosEmitidos    Recibo[]           @relation("ReciboEmitente")
  tarefas            Tarefa[]
  historicoTarefas   TarefaHistorico[]
  perfil             Perfil?            @relation(fields: [perfilId], references: [id])
  workflowStepsAssigned   WorkflowStep[] @relation("WorkflowStepAssignee")
  workflowStepsCompleted  WorkflowStep[] @relation("WorkflowStepCompletedBy")

  documentosResponsavel Documento[] @relation("DocumentoResponsavel")

  @@index([perfilId])
}

model Pessoa {
  id                 Int           @id @default(autoincrement())
  nome               String        @db.VarChar(50)
  sobrenome          String?       @db.VarChar(40)
  sexo               String?       @db.VarChar(10)
  data_nasc          DateTime?
  data_obito         DateTime?
  local_nasc         String?       @db.VarChar(100)
  estado_nasc        String?       @db.VarChar(50)
  pais_nasc          String?       @db.VarChar(50)
  vivo               Boolean       @default(true)
  batizado           String?       @db.VarChar(50)
  data_batismo       DateTime?
  local_batismo      String?       @db.VarChar(100)
  igreja_batismo     String?       @db.VarChar(150)
  profissao          String?       @db.VarChar(100)
  nacionalidade      String?       @db.VarChar(50)
  cidadanias_outras  String?       @db.VarChar(200)
  naturalizado       Boolean       @default(false)
  data_naturalizacao DateTime?
  pais_naturalizacao String?       @db.VarChar(50)
  data_emigracao     DateTime?
  local_emigracao    String?       @db.VarChar(100)
  porto_embarque     String?       @db.VarChar(100)
  data_chegada       DateTime?
  porto_chegada      String?       @db.VarChar(100)
  pais_destino       String?       @db.VarChar(50)
  navio              String?       @db.VarChar(100)
  comentario         String?
  x                  Int?
  y                  Int?
  arvoreId           Int
  paiId              Int?
  maeId              Int?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  numeroLinhagem     Int?
  requerente         String?       @default("nao")
  ordemCusto         Int?          @default(0)
  arvorePrincipal    Arvore?       @relation("ArvorePrincipal")
  custos             CustoPessoa[]
  documentos         Documento[]
  arvore             Arvore        @relation("PessoasNaArvore", fields: [arvoreId], references: [id], onDelete: Cascade)
  mae                Pessoa?       @relation("FilhosMae", fields: [maeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  filhosComoMae      Pessoa[]      @relation("FilhosMae")
  pai                Pessoa?       @relation("FilhosPai", fields: [paiId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  filhosComoPai      Pessoa[]      @relation("FilhosPai")
  unioesComoPessoa1  Uniao[]       @relation("Pessoa1")
  unioesComoPessoa2  Uniao[]       @relation("Pessoa2")
  documentacao       Boolean       @default(true)
  casado             Boolean       @default(false)
  linhaReta          Boolean       @default(true)

  @@index([arvoreId])
  @@index([pais_nasc])
  @@index([maeId])
  @@index([paiId])
}

model Uniao {
  id              Int       @id @default(autoincrement())
  data_inicio     DateTime?
  data_fim        DateTime?
  tipo            String?   @db.VarChar(30)
  local           String?   @db.VarChar(100)
  estado          String?   @db.VarChar(50)
  pais            String?   @db.VarChar(50)
  cartorio        String?   @db.VarChar(200)
  livro           String?   @db.VarChar(20)
  folha           String?   @db.VarChar(20)
  termo           String?   @db.VarChar(30)
  numero_registro String?   @db.VarChar(50)
  data_registro   DateTime?
  observacoes     String?
  pessoa1Id       Int
  pessoa2Id       Int
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  pessoa1         Pessoa    @relation("Pessoa1", fields: [pessoa1Id], references: [id], onDelete: Cascade)
  pessoa2         Pessoa    @relation("Pessoa2", fields: [pessoa2Id], references: [id], onDelete: Cascade)

  @@index([pessoa1Id])
  @@index([pessoa2Id])
}

model Arvore {
  id                Int        @id @default(autoincrement())
  nome              String     @db.VarChar(50)
  descricao         String?    @db.VarChar(200)
  commentPosX       Float?     @default(0)
  commentPosY       Float?     @default(0)
  pessoaPrincipalId Int?       @unique
  posicoesNodes     Json?
  pessoaPrincipal   Pessoa?    @relation("ArvorePrincipal", fields: [pessoaPrincipalId], references: [id], onUpdate: NoAction)
  pessoas           Pessoa[]   @relation("PessoasNaArvore")
  processos         Processo[]
}

model Documento {
  id                    Int             @id @default(autoincrement())
  pessoaId              Int
  tipo                  TipoDocumento
  status                StatusDocumento @default(PENDENTE)
  descricao             String?         @db.VarChar(200)
  cartorio              String?         @db.VarChar(200)
  livro                 String?         @db.VarChar(20)
  folha                 String?         @db.VarChar(20)
  termo                 String?         @db.VarChar(30)
  numero_registro       String?         @db.VarChar(50)
  data_registro         DateTime?
  cidade_registro       String?         @db.VarChar(100)
  estado_registro       String?         @db.VarChar(50)
  pais_registro         String?         @db.VarChar(50)
  numero                String?         @db.VarChar(50)
  orgao_emissor         String?         @db.VarChar(50)
  data_emissao          DateTime?
  data_validade         DateTime?
  arquivo_url           String?
  arquivo_nome          String?         @db.VarChar(200)
  arquivo_tamanho       Int?
  arquivo_mime_type     String?         @db.VarChar(100)
  traduzido             Boolean         @default(false)
  tradutor              String?         @db.VarChar(150)
  data_traducao         DateTime?
  workflows     Workflow[]
  arquivo_traducao_url  String?
  arquivo_traducao_nome String?         @db.VarChar(200)
  apostilado            Boolean         @default(false)
  numero_apostila       String?         @db.VarChar(50)
  data_apostila         DateTime?
  arquivo_apostila_url  String?
  observacoes           String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  data_evento           DateTime?
  pessoa                Pessoa          @relation(fields: [pessoaId], references: [id], onDelete: Cascade)

  // Identificação literal (como aparece na certidão)
  nome_registrado     String?   @db.VarChar(200)
  pai_registrado      String?   @db.VarChar(200)
  mae_registrada      String?   @db.VarChar(200)
  conjuge_registrado  String?   @db.VarChar(200)

  data_evento_documento     DateTime?
  data_registro_documento   DateTime?

  // Localidade extra
  comune              String?   @db.VarChar(100)

  // Referência registral extra
  matricula           String?   @db.VarChar(50)
  crc                 String?   @db.VarChar(50)
  protocolo           String?   @db.VarChar(50)

  // Rastreamento da solicitação
  nro_pedido          String?   @db.VarChar(50)
  canal_solicitacao   String?   @db.VarChar(50)
  link_acompanhamento String?   @db.VarChar(500)
  localizacao_fisica  String?   @db.VarChar(200)

  // ============================================================
  // ✅ NOVO: CAMPOS DE OPERAÇÃO (Central Operacional)
  // ============================================================
  responsavelId         Int?
  responsavel           Usuario?        @relation("DocumentoResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)
  dataInicioOperacao    DateTime?
  dataPrazoOperacao     DateTime?
  ultimaMovimentacao    DateTime?
  motivoBloqueio        String?         @db.VarChar(300)
  // ============================================================

  origem                String          @default("manual") @db.VarChar(20)
  ruleCode              String?         @db.VarChar(20)

  // --- Análise Documental v2 (AD2) ---
  structuredData  Json?                              // dados estruturados por tipo (birth/marriage/death)
  dataStatus      String    @default("not_filled")   // not_filled | ai_extracted | manual_filled | reviewed
  analysisStatus  String    @default("not_ready")    // not_ready | ready
  registral       Json?                              // dados registrais revisados (verdade canônica)

  @@index([pessoaId])
  @@index([tipo])
  @@index([status])
  @@index([responsavelId])
  @@index([dataPrazoOperacao])
  @@index([ultimaMovimentacao])
  @@index([origem])
  @@index([ruleCode])
}

model Status {
  id        Int        @id @default(autoincrement())
  nome      String     @db.VarChar(50)
  ordem     Int        @default(0)
  pais      Pais
  faseCode  FaseCode?
  processos Processo[]
  tarefas   Tarefa[]

  @@unique([nome, pais])
  @@index([pais])
  @@index([faseCode])
}

model Processo {
  id                Int                   @id @default(autoincrement())
  nome              String                @db.VarChar(100)
  descricao         String?               @db.VarChar(500)
  observacoes       String?
  pais              Pais
  statusId          Int
  arvoreId          Int?
  dataInicio        DateTime              @default(now())
  previsaoTermino   DateTime?
  dataConclusao     DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  percentualImposto Decimal               @default(12.00) @db.Decimal(5, 2)
  anexos            AnexoProcesso[]
  counterRecibo     CounterRecibo?
  custos            Custo[]
  custosPessoa      CustoPessoa[]
  eventos           Evento[]
  faturas           Fatura[]
  informacaoItalia  InformacaoItalia?
  mensagens         Mensagem[]
  outrosCustos      OutroCusto[]
  arvore            Arvore?               @relation(fields: [arvoreId], references: [id])
  status            Status                @relation(fields: [statusId], references: [id], onDelete: Cascade)
  analise           AnaliseDocumental?
  contratantes      ProcessoContratante[]
  requerentes       ProcessoRequerente[]
  protocolos        Protocolo[]
  receitas          Receita[]
  recibos           Recibo[]
  tarefas           Tarefa[]
  tiposServico      TipoServico[]
  pastaTraducao   PastaTraducao?
  pastaApostilamento PastaApostilamento?
  fasesFinais FaseFinal[]
  retificacaoPacotes RetificacaoPacote[]
  emissoesRetificadas EmissaoRetificada[]

  @@index([pais])
  @@index([statusId])
  @@index([arvoreId])
}

model ProcessoContratante {
  processoId    Int
  contratanteId Int
  contratante   Contratante @relation(fields: [contratanteId], references: [id], onDelete: Cascade)
  processo      Processo    @relation(fields: [processoId], references: [id], onDelete: Cascade)

  @@id([processoId, contratanteId])
}

model Tarefa {
  id                  Int               @id @default(autoincrement())
  titulo              String            @db.VarChar(200)
  descricao           String?
  processoId          Int?
  statusId            Int?
  pais                Pais?
  responsavelId       Int?
  concluida           Boolean           @default(false)
  prioridade          PrioridadeTarefa  @default(MEDIA)
  dataPrazo           DateTime?
  dataConclusao       DateTime?
  tarefaPaiId         Int?
  ordem               Int               @default(0)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  dataInicio          DateTime?
  observacoes         String?
  tipoSubtarefa       String?           @db.VarChar(20)
  prazoCobranca       Int?              @default(5)
  motivoConclusao     String?           @db.VarChar(50)
  quantidadeCobrancas Int               @default(0)
  statusTarefa        StatusTarefa      @default(NAO_INICIADA)
  ultimaCobranca      DateTime?
  processo            Processo?         @relation(fields: [processoId], references: [id], onDelete: Cascade)
  responsavel         Usuario?          @relation(fields: [responsavelId], references: [id])
  status              Status?           @relation(fields: [statusId], references: [id])
  tarefaPai           Tarefa?           @relation("Subtarefas", fields: [tarefaPaiId], references: [id], onDelete: Cascade)
  subtarefas          Tarefa[]          @relation("Subtarefas")
  historico           TarefaHistorico[]

  @@index([processoId])
  @@index([responsavelId])
  @@index([concluida])
  @@index([statusTarefa])
  @@index([tarefaPaiId])
  @@index([statusId])
  @@index([pais])
  @@index([dataPrazo])
}

model TarefaHistorico {
  id        Int      @id @default(autoincrement())
  tarefaId  Int
  usuarioId Int?
  acao      String   @db.VarChar(50)
  descricao String   @db.VarChar(500)
  dados     Json?
  createdAt DateTime @default(now())
  tarefa    Tarefa   @relation(fields: [tarefaId], references: [id], onDelete: Cascade)
  usuario   Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([tarefaId])
  @@index([usuarioId])
  @@index([createdAt])
}

model ProcessoRequerente {
  processoId   Int
  requerenteId Int
  processo     Processo   @relation(fields: [processoId], references: [id], onDelete: Cascade)
  requerente   Requerente @relation(fields: [requerenteId], references: [id], onDelete: Cascade)

  @@id([processoId, requerenteId])
}

model Contratante {
  id             Int                   @id @default(autoincrement())
  nome           String                @db.VarChar(100)
  cpf            String?               @db.VarChar(14)
  rg             String?               @db.VarChar(20)
  dataNascimento DateTime?
  sexo           String?               @db.VarChar(20)
  estadoCivil    String?               @db.VarChar(20)
  nacionalidade  String?               @db.VarChar(50)
  telefone       String?               @db.VarChar(20)
  email          String?               @db.VarChar(100)
  endereco       String?               @db.VarChar(200)
  numero         String?               @db.VarChar(20)
  complemento    String?               @db.VarChar(100)
  bairro         String?               @db.VarChar(100)
  cidade         String?               @db.VarChar(100)
  estado         String?               @db.VarChar(50)
  cep            String?               @db.VarChar(15)
  observacoes    String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  pais           String?               @default("Brasil") @db.VarChar(50)
  crnm           String?               @db.VarChar(20)
  passaporte     String?               @db.VarChar(20)
  anexos         AnexoContratante[]
  clienteAuth    ClienteAuth[]
  processos      ProcessoContratante[]
  protocolos     Protocolo[]
  recibosPagos   Recibo[]              @relation("ReciboContratante")
}

model Requerente {
  id                   Int                     @id @default(autoincrement())
  nome                 String                  @db.VarChar(100)
  cpf                  String?                 @db.VarChar(14)
  rg                   String?                 @db.VarChar(20)
  dataNascimento       DateTime?
  sexo                 String?                 @db.VarChar(20)
  estadoCivil          String?                 @db.VarChar(20)
  nacionalidade        String?                 @db.VarChar(50)
  telefone             String?                 @db.VarChar(20)
  email                String?                 @db.VarChar(100)
  endereco             String?                 @db.VarChar(200)
  numero               String?                 @db.VarChar(20)
  complemento          String?                 @db.VarChar(100)
  bairro               String?                 @db.VarChar(100)
  cidade               String?                 @db.VarChar(100)
  estado               String?                 @db.VarChar(50)
  cep                  String?                 @db.VarChar(15)
  observacoes          String?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  pais                 String?                 @default("Brasil") @db.VarChar(50)
  crnm                 String?                 @db.VarChar(20)
  passaporte           String?                 @db.VarChar(20)
  anexos               AnexoRequerente[]
  clienteAuth          ClienteAuth[]
  faturas              FaturaDestinatario[]
  pagamentosRecebidos  PagamentoDestinatario[]
  processos            ProcessoRequerente[]
  protocolos           Protocolo[]
  receitaParticipacoes ReceitaRequerente[]     @relation("ReceitaRequerentes")
  recibosPagos         Recibo[]                @relation("ReciboRequerente")
}

model Protocolo {
  id              Int              @id @default(autoincrement())
  processoId      Int
  contratanteId   Int?
  requerenteId    Int?
  consulado       Consulado
  consuladoOutro  String?          @db.VarChar(200)
  dataProtocolo   DateTime?
  numeroProtocolo String?          @db.VarChar(100)
  observacoes     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  anexos          AnexoProtocolo[]
  contratante     Contratante?     @relation(fields: [contratanteId], references: [id], onDelete: Cascade)
  processo        Processo         @relation(fields: [processoId], references: [id], onDelete: Cascade)
  requerente      Requerente?      @relation(fields: [requerenteId], references: [id], onDelete: Cascade)

  @@index([processoId])
  @@index([contratanteId])
  @@index([requerenteId])
}

model InformacaoItalia {
  id                  Int                     @id @default(autoincrement())
  processoId          Int                     @unique
  tribunal            Tribunal
  dataProtocolo       DateTime?
  dataDistribuicao    DateTime?
  numeroRuoloGenerale String?                 @db.VarChar(100)
  observacoes         String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  anexos              AnexoInformacaoItalia[]
  processo            Processo                @relation(fields: [processoId], references: [id], onDelete: Cascade)

  @@index([processoId])
}

model AnexoInformacaoItalia {
  id                 Int              @id @default(autoincrement())
  nome               String           @db.VarChar(200)
  tipo               String?          @db.VarChar(50)
  nomeArquivo        String           @db.VarChar(300)
  urlArquivo         String
  tamanho            Int?
  mimeType           String?          @db.VarChar(100)
  informacaoItaliaId Int
  createdAt          DateTime         @default(now())
  informacaoItalia   InformacaoItalia @relation(fields: [informacaoItaliaId], references: [id], onDelete: Cascade)

  @@index([informacaoItaliaId])
}

model AnexoProcesso {
  id          Int      @id @default(autoincrement())
  nome        String   @db.VarChar(200)
  tipo        String   @db.VarChar(50)
  nomeArquivo String   @db.VarChar(300)
  urlArquivo  String
  tamanho     Int?
  mimeType    String?  @db.VarChar(100)
  processoId  Int
  createdAt   DateTime @default(now())
  processo    Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)

  @@index([processoId])
}

model AnexoContratante {
  id            Int         @id @default(autoincrement())
  nome          String      @db.VarChar(200)
  tipo          String?     @db.VarChar(50)
  nomeArquivo   String      @db.VarChar(300)
  urlArquivo    String
  tamanho       Int?
  mimeType      String?     @db.VarChar(100)
  contratanteId Int
  createdAt     DateTime    @default(now())
  categoria     String?
  contratante   Contratante @relation(fields: [contratanteId], references: [id], onDelete: Cascade)

  @@index([contratanteId])
}

model AnexoRequerente {
  id           Int        @id @default(autoincrement())
  nome         String     @db.VarChar(200)
  tipo         String?    @db.VarChar(50)
  nomeArquivo  String     @db.VarChar(300)
  urlArquivo   String
  tamanho      Int?
  mimeType     String?    @db.VarChar(100)
  requerenteId Int
  createdAt    DateTime   @default(now())
  categoria    String?
  requerente   Requerente @relation(fields: [requerenteId], references: [id], onDelete: Cascade)

  @@index([requerenteId])
}

model AnexoProtocolo {
  id          Int       @id @default(autoincrement())
  nome        String    @db.VarChar(200)
  tipo        String?   @db.VarChar(50)
  nomeArquivo String    @db.VarChar(300)
  urlArquivo  String
  tamanho     Int?
  mimeType    String?   @db.VarChar(100)
  protocoloId Int
  createdAt   DateTime  @default(now())
  protocolo   Protocolo @relation(fields: [protocoloId], references: [id], onDelete: Cascade)

  @@index([protocoloId])
}

model LogAuditoria {
  id         Int      @id @default(autoincrement())
  acao       String   @db.VarChar(50)
  entidade   String   @db.VarChar(50)
  entidadeId Int?
  descricao  String
  detalhes   Json?
  usuarioId  Int?
  criadoEm   DateTime @default(now())
  usuario    Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([entidade])
  @@index([usuarioId])
  @@index([criadoEm])
}

model Fatura {
  id              Int                  @id @default(autoincrement())
  processoId      Int
  descricao       String               @db.VarChar(200)
  valor           Decimal              @db.Decimal(10, 2)
  status          StatusFatura         @default(PENDENTE)
  dataEmissao     DateTime             @default(now())
  dataVencimento  DateTime?
  observacoes     String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  moeda           Moeda                @default(BRL)
  valorOriginal   Decimal?             @db.Decimal(10, 2)
  cambio          Decimal?             @db.Decimal(10, 4)
  metodoPagamento FormaPagamento?
  parcelas        Int                  @default(1)
  valorParcela    Decimal?             @db.Decimal(10, 2)
  processo        Processo             @relation(fields: [processoId], references: [id], onDelete: Cascade)
  destinatarios   FaturaDestinatario[]
  pagamentos      PagamentoFatura[]
  parcelasBoleto  Parcela[]            @relation("ParcelasBoleto")

  @@index([processoId])
  @@index([status])
  @@index([dataVencimento])
}

model PagamentoFatura {
  id              Int                     @id @default(autoincrement())
  faturaId        Int
  valor           Decimal                 @db.Decimal(10, 2)
  data            DateTime                @default(now())
  formaPagamento  FormaPagamento?
  comprovanteUrl  String?
  comprovanteNome String?                 @db.VarChar(200)
  observacao      String?
  createdAt       DateTime                @default(now())
  cambio          Decimal?                @db.Decimal(10, 4)
  valorOriginal   Decimal?                @db.Decimal(10, 2)
  estornado       Boolean                 @default(false)
  estornadoEm     DateTime?
  estornoMotivo   String?                 @db.VarChar(200)
  destinatarios   PagamentoDestinatario[]
  fatura          Fatura                  @relation(fields: [faturaId], references: [id], onDelete: Cascade)
  recibos         Recibo[]                @relation("ReciboPagamento")

  @@index([faturaId])
}

model PagamentoDestinatario {
  id           Int             @id @default(autoincrement())
  pagamentoId  Int
  requerenteId Int
  createdAt    DateTime        @default(now())
  pagamento    PagamentoFatura @relation(fields: [pagamentoId], references: [id], onDelete: Cascade)
  requerente   Requerente      @relation(fields: [requerenteId], references: [id], onDelete: Cascade)

  @@unique([pagamentoId, requerenteId])
  @@index([pagamentoId])
  @@index([requerenteId])
}

model TipoServico {
  id         Int           @id @default(autoincrement())
  processoId Int
  nome       String        @db.VarChar(100)
