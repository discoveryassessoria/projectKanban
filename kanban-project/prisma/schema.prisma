// ========================================
// FATURA - COBRANÇA POR PROCESSO
// ========================================
enum StatusFatura {
  PENDENTE
  PAGO
  VENCIDO
  PARCIAL
}

enum FormaPagamento {
  PIX
  CARTAO_CREDITO
  CARTAO_DEBITO
  BOLETO
  TRANSFERENCIA
  DINHEIRO
  CHEQUE
  OUTRO
}

model Fatura {
  id Int @id @default(autoincrement())

  // Vínculo com processo
  processoId Int
  processo   Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)

  // Dados da fatura
  descricao String       @db.VarChar(200)
  valor     Decimal      @db.Decimal(10, 2)
  status    StatusFatura @default(PENDENTE)

  // Datas
  dataEmissao    DateTime  @default(now())
  dataVencimento DateTime?

  // Observações
  observacoes String? @db.Text

  moeda           Moeda           @default(BRL)
  valorOriginal   Decimal?        @db.Decimal(10, 2)
  cambio          Decimal?        @db.Decimal(10, 4)
  metodoPagamento FormaPagamento?
  parcelas        Int             @default(1)
  valorParcela    Decimal?        @db.Decimal(10, 2)

  // ✅ NOVO: Pagamentos vinculados (histórico completo)
  pagamentos PagamentoFatura[]

  destinatarios FaturaDestinatario[]

  parcelasBoleto Parcela[] @relation("ParcelasBoleto")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([processoId])
  @@index([status])
  @@index([dataVencimento])
}

model PagamentoFatura {
  id Int @id @default(autoincrement())

  // Vínculo com fatura
  faturaId Int
  fatura   Fatura @relation(fields: [faturaId], references: [id], onDelete: Cascade)

  // Dados do pagamento
  valor          Decimal         @db.Decimal(10, 2)
  data           DateTime        @default(now())
  formaPagamento FormaPagamento?

  // Para moedas estrangeiras
  valorOriginal Decimal? @db.Decimal(10, 2)
  cambio        Decimal? @db.Decimal(10, 4)

  // Comprovante
  comprovanteUrl  String? @db.Text
  comprovanteNome String? @db.VarChar(200)

  // Observação
  observacao String? @db.Text

  // Destinatários do pagamento
  destinatarios PagamentoDestinatario[]

  estornado     Boolean   @default(false)
  estornadoEm   DateTime?
  estornoMotivo String?   @db.VarChar(200)
  recibos       Recibo[]  @relation("ReciboPagamento")

  createdAt DateTime @default(now())

  @@index([faturaId])
}

model PagamentoDestinatario {
  id Int @id @default(autoincrement())

  pagamentoId Int
  pagamento   PagamentoFatura @relation(fields: [pagamentoId], references: [id], onDelete: Cascade)

  requerenteId Int
  requerente   Requerente @relation(fields: [requerenteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([pagamentoId, requerenteId])
  @@index([pagamentoId])
  @@index([requerenteId])
}

// ========================================
// TIPO DE SERVIÇO - COLUNAS DE CUSTO POR PROCESSO
// ========================================
model TipoServico {
  id Int @id @default(autoincrement())

  // Vínculo com processo
  processoId Int
  processo   Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)

  // Dados do tipo de serviço
  nome  String @db.VarChar(100) // Ex: "Certidão Inteiro Teor", "Tradução", etc.
  ordem Int    @default(0) // Ordem de exibição na tabela

  createdAt DateTime @default(now())

  // Custos vinculados
  custos CustoPessoa[]

  @@index([processoId])
}

// ========================================
// CUSTO POR PESSOA/DOCUMENTO - VALORES DA PLANILHA
// ✅ ATUALIZADO: Agora suporta custos por documento (tipoRegistro)
// ========================================
model CustoPessoa {
  id Int @id @default(autoincrement())

  // Vínculos
  processoId Int
  processo   Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)

  pessoaId Int
  pessoa   Pessoa @relation(fields: [pessoaId], references: [id], onDelete: Cascade)

  tipoServicoId Int
  tipoServico   TipoServico @relation(fields: [tipoServicoId], references: [id], onDelete: Cascade)

  // ✅ NOVO: Tipo de registro (Nascimento, Casamento, Óbito)
  // Permite custos diferentes para cada documento da mesma pessoa
  tipoRegistro String? @db.VarChar(20)

  // Valor
  valor      Decimal @default(0) @db.Decimal(10, 2)
  observacao String? @db.VarChar(200)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Constraint único: uma pessoa só pode ter um valor por tipo de serviço E tipo de registro no processo
  @@unique([processoId, pessoaId, tipoServicoId, tipoRegistro])
  @@index([processoId])
  @@index([pessoaId])
  @@index([tipoServicoId])
}

// ========================================
// MÓDULO FINANCEIRO COMPLETO
// ========================================

// ========================================
// ENUMS FINANCEIROS
// ========================================

enum TipoTransacao {
  ENTRADA
  SAIDA
}

enum StatusContaPagar {
  PENDENTE
  PAGO
  VENCIDO
  CANCELADO
  AGENDADO
}

enum RecorrenciaTipo {
  UNICA
  SEMANAL
  MENSAL
  TRIMESTRAL
  SEMESTRAL
  ANUAL
}

// ========================================
// CATEGORIA FINANCEIRA
// ========================================
model CategoriaFinanceira {
  id        Int           @id @default(autoincrement())
  nome      String        @db.VarChar(100)
  tipo      TipoTransacao // ENTRADA ou SAIDA
  cor       String?       @db.VarChar(7) // Hex color para gráficos
  icone     String?       @db.VarChar(50)
  descricao String?       @db.VarChar(200)

  // Categoria pai (para subcategorias)
  categoriaPaiId Int?
  categoriaPai   CategoriaFinanceira?  @relation("Subcategorias", fields: [categoriaPaiId], references: [id], onDelete: SetNull)
  subcategorias  CategoriaFinanceira[] @relation("Subcategorias")

  ativo Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  contasPagar ContaPagar[]
  transacoes  Transacao[]

  @@index([tipo])
}

// ========================================
// CONTA BANCÁRIA
// ========================================
model ContaBancaria {
  id        Int     @id @default(autoincrement())
  nome      String  @db.VarChar(100) // Ex: "Conta Principal", "Caixa"
  banco     String? @db.VarChar(100)
  agencia   String? @db.VarChar(20)
  conta     String? @db.VarChar(30)
  tipoConta String? @db.VarChar(30) // Corrente, Poupança, Caixa

  // Chaves Pix
  chavePix     String? @db.VarChar(100)
  tipoChavePix String? @db.VarChar(20) // CPF, CNPJ, Email, Telefone, Aleatoria

  saldoInicial Decimal @default(0) @db.Decimal(12, 2)
  saldoAtual   Decimal @default(0) @db.Decimal(12, 2)

  cor       String? @db.VarChar(7) // Para identificação visual
  ativo     Boolean @default(true)
  principal Boolean @default(false) // Conta principal

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  transacoes  Transacao[]
  contasPagar ContaPagar[]

  @@index([ativo])
}

// ========================================
// FORNECEDOR
// ========================================
model Fornecedor {
  id Int @id @default(autoincrement())

  // Dados básicos
  nome         String  @db.VarChar(150)
  nomeFantasia String? @db.VarChar(150)
  tipo         String  @db.VarChar(20) // PF ou PJ

  // Documentos
  cpfCnpj            String? @db.VarChar(20)
  inscricaoEstadual  String? @db.VarChar(20)
  inscricaoMunicipal String? @db.VarChar(20)

  // Contato
  telefone String? @db.VarChar(20)
  celular  String? @db.VarChar(20)
  email    String? @db.VarChar(100)
  website  String? @db.VarChar(200)

  // Endereço
  cep         String? @db.VarChar(10)
  endereco    String? @db.VarChar(200)
  numero      String? @db.VarChar(20)
  complemento String? @db.VarChar(100)
  bairro      String? @db.VarChar(100)
  cidade      String? @db.VarChar(100)
  estado      String? @db.VarChar(2)

  // Dados bancários do fornecedor (para pagamentos)
  banco        String? @db.VarChar(100)
  agencia      String? @db.VarChar(20)
  conta        String? @db.VarChar(30)
  tipoConta    String? @db.VarChar(20)
  chavePix     String? @db.VarChar(100)
  tipoChavePix String? @db.VarChar(20)

  observacoes String? @db.Text
  ativo       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  contasPagar ContaPagar[]

  @@index([nome])
  @@index([cpfCnpj])
  @@index([ativo])
}

// ========================================
// CONTA A PAGAR
// ========================================
model ContaPagar {
  id Int @id @default(autoincrement())

  // Descrição
  descricao   String  @db.VarChar(200)
  observacoes String? @db.Text

  // Fornecedor (opcional - pode ser despesa sem fornecedor)
  fornecedorId Int?
  fornecedor   Fornecedor? @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)

  // Categoria
  categoriaId Int?
  categoria   CategoriaFinanceira? @relation(fields: [categoriaId], references: [id], onDelete: SetNull)

  // Valores
  valor     Decimal  @db.Decimal(12, 2)
  valorPago Decimal? @db.Decimal(12, 2)
  desconto  Decimal? @default(0) @db.Decimal(12, 2)
  juros     Decimal? @default(0) @db.Decimal(12, 2)
  multa     Decimal? @default(0) @db.Decimal(12, 2)

  // Datas
  dataEmissao     DateTime  @default(now())
  dataVencimento  DateTime
  dataPagamento   DateTime?
  dataCompetencia DateTime? // Mês de competência contábil

  // Status
  status StatusContaPagar @default(PENDENTE)

  // Pagamento
  formaPagamento  FormaPagamento?
  contaBancariaId Int?
  contaBancaria   ContaBancaria?  @relation(fields: [contaBancariaId], references: [id], onDelete: SetNull)

  // Documento fiscal
  numeroDocumento String? @db.VarChar(50)
  tipoDocumento   String? @db.VarChar(50) // NF, Boleto, Recibo, etc

  // Comprovante
  comprovanteUrl  String? @db.Text
  comprovanteNome String? @db.VarChar(200)

  // Recorrência
  recorrencia   RecorrenciaTipo @default(UNICA)
  contaPaiId    Int? // Se for parcela de uma conta parcelada
  numeroParcela Int?
  totalParcelas Int?

  // Vínculo com processo (opcional)
  processoId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Transação gerada quando pago
  transacoes Transacao[]

  @@index([fornecedorId])
  @@index([categoriaId])
  @@index([status])
  @@index([dataVencimento])
  @@index([processoId])
}

// ========================================
// TRANSAÇÃO (FLUXO DE CAIXA)
// ========================================
model Transacao {
  id Int @id @default(autoincrement())

  // Tipo e descrição
  tipo        TipoTransacao
  descricao   String        @db.VarChar(200)
  observacoes String?       @db.Text

  // Valores
  valor Decimal @db.Decimal(12, 2)

  // Data
  data            DateTime  @default(now())
  dataCompetencia DateTime? // Mês de competência

  // Conta bancária
  contaBancariaId Int
  contaBancaria   ContaBancaria @relation(fields: [contaBancariaId], references: [id], onDelete: Restrict)

  // Categoria
  categoriaId Int?
  categoria   CategoriaFinanceira? @relation(fields: [categoriaId], references: [id], onDelete: SetNull)

  // Origem da transação (qual entidade gerou)
  // Pode ser uma fatura paga (entrada) ou conta paga (saída)
  faturaId     Int?
  contaPagarId Int?
  contaPagar   ContaPagar? @relation(fields: [contaPagarId], references: [id], onDelete: SetNull)

  // Vínculo com processo
  processoId Int?

  // Conciliação bancária
  conciliado      Boolean   @default(false)
  dataConciliacao DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tipo])
  @@index([contaBancariaId])
  @@index([categoriaId])
  @@index([data])
  @@index([faturaId])
  @@index([contaPagarId])
  @@index([processoId])
}

// ========================================
// CENTRO DE CUSTO (OPCIONAL - PARA ANÁLISE)
// ========================================
model CentroCusto {
  id        Int     @id @default(autoincrement())
  nome      String  @db.VarChar(100)
  descricao String? @db.VarChar(200)
  cor       String? @db.VarChar(7)
  ativo     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ativo])
}

// ========================================
// EVENTO - COMPROMISSOS DO PROCESSO
// ========================================
model Evento {
  id Int @id @default(autoincrement())

  // Vínculo com processo (opcional para eventos gerais)
  processoId Int?
  processo   Processo? @relation(fields: [processoId], references: [id], onDelete: Cascade)

  // Dados do evento
  titulo    String     @db.VarChar(200)
  descricao String?    @db.Text
  tipo      TipoEvento @default(OUTRO)

  // Data e hora
  dataInicio DateTime
  dataFim    DateTime?
  diaInteiro Boolean   @default(false)

  // Local
  local String? @db.VarChar(200)

  // Lembrete (dias antes)
  lembreteDias Int?

  // Cor para o calendário (hex)
  cor String? @db.VarChar(7)

  // Observações
  observacoes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([processoId])
  @@index([dataInicio])
  @@index([tipo])
}

// ========================================
// ✅ NOVO: BLOG - POSTS PARA LANDING PAGE
// ========================================
model BlogPost {
  id Int @id @default(autoincrement())

  // Conteúdo
  titulo   String  @db.VarChar(200)
  slug     String  @unique @db.VarChar(220)
  resumo   String  @db.VarChar(500)
  conteudo String? @db.Text

  // Imagem de capa
  imagemUrl String? @db.Text
  imagemAlt String? @db.VarChar(200)

  // Categorização
  categoria String @db.VarChar(100)

  // Meta
  tempoLeitura Int        @default(5)
  status       StatusPost @default(RASCUNHO)
  destaque     Boolean    @default(false)

  // Datas
  dataPublicacao DateTime?

  // SEO
  metaTitle       String? @db.VarChar(70)
  metaDescription String? @db.VarChar(160)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([dataPublicacao])
  @@index([categoria])
  @@index([destaque])
}

model FaturaDestinatario {
  id           Int        @id @default(autoincrement())
  faturaId     Int
  fatura       Fatura     @relation(fields: [faturaId], references: [id], onDelete: Cascade)
  requerenteId Int
  requerente   Requerente @relation(fields: [requerenteId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([faturaId, requerenteId])
  @@index([faturaId])
  @@index([requerenteId])
}

// ========================================
// PARCELA DE BOLETO
// ========================================
model Parcela {
  id Int @id @default(autoincrement())

  // Vínculo com fatura
  faturaId Int
  fatura   Fatura @relation("ParcelasBoleto", fields: [faturaId], references: [id], onDelete: Cascade)

  // Dados da parcela
  numero         Int // 1, 2, 3...
  valor          Decimal  @db.Decimal(10, 2)
  dataVencimento DateTime

  // Status
  pago          Boolean   @default(false)
  dataPagamento DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([faturaId, numero])
  @@index([faturaId])
  @@index([dataVencimento])
  @@index([pago])
}

model ClienteAuth {
  id Int @id @default(autoincrement())

  // Login
  email     String @unique @db.VarChar(100)
  senhaHash String @db.VarChar(255)

  // Vínculo flexível: pode ser contratante OU requerente
  contratanteId Int?
  contratante   Contratante? @relation(fields: [contratanteId], references: [id], onDelete: Cascade)

  requerenteId Int?
  requerente   Requerente? @relation(fields: [requerenteId], references: [id], onDelete: Cascade)

  // Controle
  ativo          Boolean   @default(true)
  primeiroAcesso Boolean   @default(true) // Forçar troca de senha no 1º login
  ultimoLogin    DateTime?

  // Token de reset de senha
  resetToken       String?   @db.VarChar(255)
  resetTokenExpira DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mensagens Mensagem[]

  @@index([contratanteId])
  @@index([requerenteId])
}

// ========================================
// MENSAGEM - CHAT ENTRE CLIENTE E EQUIPE
// ========================================
model Mensagem {
  id        Int       @id @default(autoincrement())
  editadoEm DateTime?
  apagada   Boolean   @default(false)

  // Vínculo com processo
  processoId Int
  processo   Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)

  // Conteúdo
  conteudo String @db.Text

  // Remetente (um dos dois será preenchido)
  usuarioId Int? // Equipe (admin/funcionário)
  usuario   Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  clienteAuthId Int? // Cliente (contratante/requerente)
  clienteAuth   ClienteAuth? @relation(fields: [clienteAuthId], references: [id], onDelete: SetNull)

  // Controle de leitura
  lidoPeloCliente Boolean @default(false)
  lidoPelaEquipe  Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([processoId])
  @@index([clienteAuthId])
  @@index([usuarioId])
  @@index([createdAt])
}

model Perfil {
  id        Int     @id @default(autoincrement())
  nome      String  @unique @db.VarChar(50) // "Administrador", "Gerente", "Assistente", "Estagiário"
  descricao String? @db.VarChar(200)

  // Permissões padrão do perfil (JSON com todas as permissões)
  permissoes Json // { "tarefas.ver": true, "tarefas.criar": false, ... }

  // Se é perfil padrão do sistema (não pode ser excluído)
  sistema Boolean @default(false)

  cor String? @db.VarChar(7) // Cor para identificação visual

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuarios Usuario[]
}

// ========================================
// RECIBO - Recibos de pagamento numerados
// ========================================
model Recibo {
  id Int @id @default(autoincrement())

  // Vínculo com processo
  processoId Int
  processo   Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)

  // Numeração sequencial RCB-XXXX
  numero String @unique @db.VarChar(20)

  // Dados do recibo
  data       DateTime @default(now())
  valorTotal Decimal  @db.Decimal(12, 2)
  descricao  String   @db.Text

  // Pagador (um dos dois)
  pagadorRequerenteId  Int?
  pagadorRequerente    Requerente?  @relation("ReciboRequerente", fields: [pagadorRequerenteId], references: [id], onDelete: SetNull)
  pagadorContratanteId Int?
  pagadorContratante   Contratante? @relation("ReciboContratante", fields: [pagadorContratanteId], references: [id], onDelete: SetNull)
  pagadorNome          String?      @db.VarChar(200)

  // Pagamentos que compõem este recibo (M:N)
  pagamentos PagamentoFatura[] @relation("ReciboPagamento")

  // PDF gerado
  pdfUrl  String? @db.Text
  pdfNome String? @db.VarChar(200)

  // Auditoria
  emitidoPorId Int?
  emitidoPor   Usuario? @relation("ReciboEmitente", fields: [emitidoPorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([processoId])
  @@index([numero])
  @@index([pagadorRequerenteId])
  @@index([pagadorContratanteId])
}

// ========================================
// COUNTER RECIBO - Contador sequencial por processo
// ========================================
model CounterRecibo {
  processoId    Int      @id
  processo      Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)
  proximoNumero Int      @default(1)
  atualizadoEm  DateTime @updatedAt
}

// ========================================
// ✅ NOVO: OUTRO CUSTO - Lançamentos manuais de custos/receitas do processo
// (Honorários Discovery, Advogado Itália, Cartório, Consulado, Taxas, etc.)
// ========================================
model OutroCusto {
  id Int @id @default(autoincrement())

  // Vínculo com processo
  processoId Int
  processo   Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)

  // Natureza: COBRAR (receita) ou REPASSAR (despesa a pagar)
  natureza NaturezaOutroCusto

  // Classificação
  tipo       String  @db.VarChar(100) // "Honorários Discovery", "Advogado", "Cartório", etc.
  descricao  String  @db.VarChar(200)
  fornecedor String? @db.VarChar(150)

  // Valor e moeda
  valor  Decimal  @db.Decimal(12, 2)
  moeda  Moeda    @default(BRL)
  cambio Decimal? @db.Decimal(10, 4)

  // Datas
  vencimento DateTime?

  // Flags
  interno   Boolean @default(false) // Custo interno (não repassado ao cliente)
  repassado Boolean @default(false) // Já foi repassado ao cliente
  pago      Boolean @default(false) // Marcação manual de "pago"

  // Observações
  observacao String? @db.Text

  // Pagamentos parciais
  pagamentos PagamentoOutroCusto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([processoId])
  @@index([natureza])
  @@index([vencimento])
}

// ========================================
// ✅ NOVO: PAGAMENTO DE OUTRO CUSTO - Histórico de pagamentos parciais
// ========================================
model PagamentoOutroCusto {
  id Int @id @default(autoincrement())

  // Vínculo
  outroCustoId Int
  outroCusto   OutroCusto @relation(fields: [outroCustoId], references: [id], onDelete: Cascade)

  // Dados do pagamento
  valor Decimal         @db.Decimal(12, 2)
  data  DateTime        @default(now())
  forma FormaPagamento?

  // Quem pagou (opcional - pode ser requerente, contratante ou texto livre)
  pagadorTipo String? @db.VarChar(20) // "REQUERENTE" | "CONTRATANTE" | "OUTRO"
  pagadorId   Int?
  pagadorNome String? @db.VarChar(200)

  // Comprovante
  comprovanteUrl  String? @db.Text
  comprovanteNome String? @db.VarChar(200)

  // Observação
  observacao String? @db.Text

  // Estorno
  estornado     Boolean   @default(false)
  estornadoEm   DateTime?
  estornoMotivo String?   @db.VarChar(200)

  createdAt DateTime @default(now())

  @@index([outroCustoId])
}

// ============================================================
// 1. ENUMS NOVOS
// ============================================================
// Reaproveitar enums existentes: Moeda (BRL/EUR/USD), FormaPagamento

enum FxRule {
  FIXO
  VARIAVEL
}

enum StatusParcela {
  PENDENTE
  RECEBIDA // usado em parcelas de Receita
  PAGA // usado em parcelas de Custo
  CANCELADA
}

enum CategoriaReceita {
  HONORARIOS
  REEMBOLSO
  PASTA_DOCUMENTAL
  OUTROS
}

enum TipoCusto {
  SERVICO
  IMPOSTO
  DOCUMENTO
  DESPESA
}

enum CategoriaCusto {
  TRADUCOES_JURAMENTACOES
  APOSTILAMENTOS
  HONORARIOS_ESCRITORIO
  TAXAS_CONSULARES
  OUTROS
}

enum TipoEventoFinanceiro {
  CRIACAO
  EDICAO
  CANCELAMENTO
  RECEBIMENTO
  PAGAMENTO
  EDICAO_RECEBIMENTO
  EDICAO_PAGAMENTO
  ESTORNO_RECEBIMENTO
  ESTORNO_PAGAMENTO
}

// ============================================================
// 2. RECEITA — lançamento de receita (REC-XXXXXX)
// ============================================================
model Receita {
  id     Int    @id @default(autoincrement())
  codigo String @unique @db.VarChar(20) // "REC-XXXXXX"

  // Vínculo com processo
  processoId Int
  processo   Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)

  // Classificação
  categoria CategoriaReceita @default(OUTROS)
  descricao String           @db.VarChar(300)

  // Valor e moeda (moeda primária do novo modelo é EUR, mas aceita BRL/USD)
  moeda Moeda   @default(EUR)
  valor Decimal @db.Decimal(12, 2)

  // Câmbio
  fxEstimado   Decimal   @db.Decimal(10, 4)
  fxRule       FxRule    @default(VARIAVEL)
  fxFixo       Decimal?  @db.Decimal(10, 4)
  fxData       DateTime?
  valorBrlFixo Decimal?  @db.Decimal(12, 2)

  // Parcelamento
  nParcelas     Int      @default(1)
  data1         DateTime
  periodicidade String   @default("Mensal") @db.VarChar(20)

  // Estado
  cancelada Boolean @default(false)
  status          ReceitaStatus  @default(ATIVA)

  // Observações
  observacoes String? @db.Text

  // Relacionamentos
  parcelas    ParcelaFinanceira[]
  requerentes ReceitaRequerente[]
  eventos     EventoFinanceiro[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([processoId])
  @@index([categoria])
  @@index([cancelada])
  @@index([codigo])
}

// ============================================================
// 3. CUSTO — lançamento de custo (CUS-XXXXXX)
// ============================================================
model Custo {
  id     Int    @id @default(autoincrement())
  codigo String @unique @db.VarChar(20) // "CUS-XXXXXX"

  // Vínculo com processo
  processoId Int
  processo   Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)

  // Classificação
  tipo       TipoCusto      @default(SERVICO)
  categoria  CategoriaCusto @default(OUTROS)
  descricao  String         @db.VarChar(300)
  fornecedor String?        @db.VarChar(200)

  // Valor e moeda
  moeda Moeda   @default(EUR)
  valor Decimal @db.Decimal(12, 2)

  // Câmbio
  fxEstimado   Decimal   @db.Decimal(10, 4)
  fxRule       FxRule    @default(VARIAVEL)
  fxFixo       Decimal?  @db.Decimal(10, 4)
  fxData       DateTime?
  valorBrlFixo Decimal?  @db.Decimal(12, 2)

  // Parcelamento
  nParcelas  Int      @default(1)
  vencimento DateTime

  // Custo vinculado a categoria de receita (lógica do HTML)
  // Ex: "Imposto 12% sobre Honorários" → custoOperacional=true,
  //     categoriaVinculada=HONORARIOS, percentualVinculado=12
  custoOperacional    Boolean           @default(false)
  categoriaVinculada  CategoriaReceita?
  percentualVinculado Decimal?          @db.Decimal(5, 2)

  // Forma de pagamento default
  formaPagamento FormaPagamento?

  // Estado
  cancelado Boolean @default(false)

  // Observações
  observacoes String? @db.Text

  // Relacionamentos
  parcelas ParcelaFinanceira[]
  eventos  EventoFinanceiro[]

  status      CustoStatus @default(ATIVA)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([processoId])
  @@index([tipo])
  @@index([categoria])
  @@index([cancelado])
  @@index([codigo])
}

// ============================================================
// 4. PARCELA FINANCEIRA — parcela de Receita OU Custo
// ============================================================
// Tabela única. Exatamente um de receitaId/custoId é preenchido.
// (Validação garantida na camada de aplicação — Prisma não tem
// CHECK constraint nativo no datasource postgres pelo schema.)
model ParcelaFinanceira {
  id Int @id @default(autoincrement())

  // Vínculo (exatamente um dos dois)
  receitaId Int?
  receita   Receita? @relation(fields: [receitaId], references: [id], onDelete: Cascade)
  custoId   Int?
  custo     Custo?   @relation(fields: [custoId], references: [id], onDelete: Cascade)

  // Dados da parcela
  numero     Int // 1, 2, 3...
  vencimento DateTime
  valor      Decimal  @db.Decimal(12, 2) // na moeda do pai

  // Status
  status StatusParcela @default(PENDENTE)

  // Preenchidos quando paga/recebida
  cambioAplicado Decimal?        @db.Decimal(10, 4)
  valorBrl       Decimal?        @db.Decimal(12, 2)
  dataPagamento  DateTime?
  formaPagamento FormaPagamento?
  banco          String?         @db.VarChar(100)

  // Comprovante
  comprovanteUrl  String? @db.Text
  comprovanteNome String? @db.VarChar(200)

  // Observações
  observacoes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([receitaId, numero])
  @@unique([custoId, numero])
  @@index([receitaId])
  @@index([custoId])
  @@index([status])
  @@index([vencimento])
}

// ============================================================
// 5. RECEITA REQUERENTE — distribuição da Receita por participante
// ============================================================
// Snapshot com FK opcional pra Requerente real do schema (que pode
// ou não estar cadastrado no momento da criação da Receita).
model ReceitaRequerente {
  id Int @id @default(autoincrement())

  receitaId Int
  receita   Receita @relation(fields: [receitaId], references: [id], onDelete: Cascade)

  // FK opcional pro Requerente real do schema
  requerenteId Int?
  requerente   Requerente? @relation("ReceitaRequerentes", fields: [requerenteId], references: [id], onDelete: SetNull)

  // Snapshot dos dados (mesmo formato do HTML: requerentes:[{idx,nome,idade,status,percentual}])
  idx            Int // posição na lista (0, 1, 2...)
  nome           String  @db.VarChar(200)
  idade          Int?
  statusFamiliar String? @db.VarChar(20) // "Adulto" | "Menor"
  percentual     Decimal @default(100.00) @db.Decimal(5, 2) // 0-100, soma=100 dentro da Receita

  createdAt DateTime @default(now())

  @@unique([receitaId, idx])
  @@index([receitaId])
  @@index([requerenteId])
}

// ============================================================
// 6. EVENTO FINANCEIRO — histórico (substitui array `historico`)
// ============================================================
model EventoFinanceiro {
  id Int @id @default(autoincrement())

  // Vínculo (exatamente um dos dois)
  receitaId Int?
  receita   Receita? @relation(fields: [receitaId], references: [id], onDelete: Cascade)
  custoId   Int?
  custo     Custo?   @relation(fields: [custoId], references: [id], onDelete: Cascade)

  // Quem fez
  usuarioId Int?
  usuario   Usuario? @relation("EventoFinanceiroUsuario", fields: [usuarioId], references: [id], onDelete: SetNull)

  // Tipo e descrição
  tipo      TipoEventoFinanceiro
  descricao String               @db.VarChar(500)

  // Valores envolvidos (espelho do `Movimento` do HTML)
  valor    Decimal? @db.Decimal(12, 2)
  cambio   Decimal? @db.Decimal(10, 4)
  valorBrl Decimal? @db.Decimal(12, 2)

  // Dados extras (parcela afetada, valores antes/depois de edição, etc)
  dados Json?

  createdAt DateTime @default(now())

  @@index([receitaId])
  @@index([custoId])
  @@index([usuarioId])
  @@index([createdAt])
}
