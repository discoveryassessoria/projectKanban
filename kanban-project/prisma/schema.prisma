// Catálogo das fases (building blocks do workflow)
model CatalogoFase {
  id                Int      @id @default(autoincrement())
  phaseKey          String   @unique @db.VarChar(60)
  label             String   @db.VarChar(120)
  ordemPadrao       Int      @default(0)
  requiredPadrao    Boolean  @default(true)
  conditionalPadrao Boolean  @default(false)
  slaDiasPadrao     Int      @default(30)
  ativo             Boolean  @default(true)
  criadoEm          DateTime @default(now())
  atualizadoEm      DateTime @updatedAt
}

// Workflow Macro — 1:1 com o tipo de processo
model MacroWorkflow {
  id             Int      @id @default(autoincrement())
  tipoProcessoId Int      @unique
  tipoProcesso   TipoProcessoNacionalidade @relation(fields: [tipoProcessoId], references: [id], onDelete: Cascade)
  name           String   @db.VarChar(200)
  ativo          Boolean  @default(true)
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt
  fases          FaseMacro[]
}

// Fases do workflow (a coluna variável)
model FaseMacro {
  id              Int      @id @default(autoincrement())
  macroWorkflowId Int
  macroWorkflow   MacroWorkflow @relation(fields: [macroWorkflowId], references: [id], onDelete: Cascade)
  phaseKey        String   @db.VarChar(60)
  label           String   @db.VarChar(120)
  ordem           Int      @default(0)
  required        Boolean  @default(true)
  conditional     Boolean  @default(false)
  entryRule       String   @default("previous_phase_completed") @db.VarChar(40)
  exitRule        String?  @db.VarChar(120)
  slaDays         Int      @default(30)
  showInKanban    Boolean  @default(true)
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt
  @@unique([macroWorkflowId, phaseKey])
  @@index([macroWorkflowId])
}

model ModeloInternoFase {
  id                Int      @id @default(autoincrement())
  name              String   @db.VarChar(200)
  modeKey           String   @db.VarChar(60)
  category          String?  @db.VarChar(40)   // = phaseKey "principal" (retificacao/protocolado/traducao/apostilamento...) — âncora do @@unique
  recommendedPhases Json?                       // ← NOVO: lista de phaseKeys recomendadas (CatalogoFase)
  description       String?  @db.Text
  conditionOfUse    String?  @db.Text
  operationalImpact String?  @db.Text
  documentalImpact  String?  @db.Text
  financialImpact   String?  @db.Text
  protocolImpact    String?  @db.Text
  isSystemTemplate  Boolean  @default(false)
  usedByCount       Int      @default(0)        // ← NOVO: quantas fases usam (bloqueia Excluir quando > 0)
  arquivado         Boolean  @default(false)
  criadoEm          DateTime @default(now())
  atualizadoEm      DateTime @updatedAt

  @@unique([category, modeKey])
  @@index([category])
}

model ModeloWorkflowInterno {
  id                Int      @id @default(autoincrement())
  templateKey       String   @unique @db.VarChar(80)   // âncora do seed, ex: iw_tpl_genealogy_default
  name              String   @db.VarChar(200)
  description       String?  @db.Text
  category          String?  @db.VarChar(40)            // = phaseKey "principal"
  recommendedPhases Json?                                // lista de phaseKeys (CatalogoFase)
  isSystemTemplate  Boolean  @default(false)
  usedByCount       Int      @default(0)                 // quantas fases usam (bloqueia Excluir quando > 0)
  arquivado         Boolean  @default(false)
  criadoEm          DateTime @default(now())
  atualizadoEm      DateTime @updatedAt

  passos            PassoWorkflowInterno[]

  @@index([category])
}

model PassoWorkflowInterno {
  id                     Int      @id @default(autoincrement())
  modeloId               Int
  modelo                 ModeloWorkflowInterno @relation(fields: [modeloId], references: [id], onDelete: Cascade)
  ordem                  Int
  name                   String   @db.VarChar(200)
  description            String?  @db.Text
  generatesTask          Boolean  @default(true)         // "Gera tarefa"
  required               Boolean  @default(true)         // "Obrigatório"
  defaultResponsibleRole String?  @db.VarChar(80)        // "Responsável padrão"
  defaultPriority        String   @default("medium") @db.VarChar(20)  // low | medium | high
  defaultSlaDays         Int      @default(3)
  completionCondition    String?  @db.Text
  checklist              Json?                            // lista de strings (um item por linha)

  @@index([modeloId])
}

model ModeloAutomacao {
  id                 Int      @id @default(autoincrement())
  templateKey        String   @unique @db.VarChar(80)
  name               String   @db.VarChar(200)
  description        String?  @db.Text
  type               String   @default("task") @db.VarChar(30)   // task | financial | document | event | protocol | phase_transition | alert
  category           String?  @db.VarChar(40)                     // = phaseKey "principal"
  recommendedPhases  Json?                                         // lista de phaseKeys
  scope              String   @default("phase") @db.VarChar(40)    // phase | person_document | ...
  trigger            String?  @db.VarChar(60)                      // quando acontece
  action             String?  @db.VarChar(80)                      // o que o sistema faz
  conditions         Json?                                         // [{ field, operator, value }] (não editável na UI)
  defaultParams      Json?                                         // { responsibleRole, priority, slaDays, checklist, financialType? }
  idempotencyPattern String   @default("processId+phaseKey") @db.VarChar(120)
  isSystemTemplate   Boolean  @default(false)
  usedByCount        Int      @default(0)                          // bloqueia Excluir quando > 0
  arquivado          Boolean  @default(false)
  criadoEm           DateTime @default(now())
  atualizadoEm       DateTime @updatedAt

  @@index([category])
  @@index([type])
}

model PhaseInternalMode {
  id                Int      @id @default(autoincrement())
  modeUid           String   @unique @db.VarChar(140)   // {tipoProcessoId|'all'}::{phaseKey}::{key}
  templateId        Int?                                 // → ModeloInternoFase (solto; null = ad-hoc/seed)
  tipoProcessoId    Int?                                 // → TipoProcessoNacionalidade (solto; null = todos os processos)
  phaseKey          String   @db.VarChar(40)
  key               String   @db.VarChar(60)            // chave do modo (slug, único dentro de processo+fase)
  label             String   @db.VarChar(200)
  description       String?  @db.Text
  condition         String?  @db.Text                   // condição de uso (vem de conditionOfUse do modelo)
  impactOperational String?  @db.Text
  impactDocument    String?  @db.Text
  impactFinancial   String?  @db.Text
  impactProtocol    String?  @db.Text
  active            Boolean  @default(true)
  arquivado         Boolean  @default(false)
  criadoEm          DateTime @default(now())
  atualizadoEm      DateTime @updatedAt

  @@index([phaseKey])
  @@index([tipoProcessoId])
}

model PhaseInternalWorkflow {
  id             Int      @id @default(autoincrement())
  // {tipoProcessoId|'all'}::{phaseKey} para o workflow PRIMÁRIO de uma fase.
  // (âncora de unicidade — 1 workflow por processo+fase; null = global/todos)
  wfUid          String   @unique @db.VarChar(140)
  templateId     Int?     // → ModeloWorkflowInterno (solto; null = ad-hoc/seed)
  tipoProcessoId Int?     // → TipoProcessoNacionalidade (solto; null = TODOS os processos)
  phaseKey       String   @db.VarChar(60)
  name           String   @db.VarChar(200)
  active         Boolean  @default(true)
  arquivado      Boolean  @default(false)
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt

  passos         PhaseInternalWorkflowStep[]

  @@index([phaseKey])
  @@index([tipoProcessoId])
}

model PhaseInternalWorkflowStep {
  id             Int      @id @default(autoincrement())
  workflowId     Int
  workflow       PhaseInternalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  key            String   @db.VarChar(80)   // slug (único dentro do workflow — controlado na UI)
  label          String   @db.VarChar(200)
  description    String?  @db.Text
  ordem          Int      @default(0)
  createsTask    Boolean  @default(true)    // "Gera tarefa"
  required       Boolean  @default(true)    // "Obrigatório"
  owner          String?  @db.VarChar(120)  // "Responsável padrão"
  priority       String   @default("medium") @db.VarChar(20)  // low | medium | high
  slaDays        Int      @default(0)
  completionRule String?  @db.Text          // "Condição de conclusão"
  checklist      Json?

  // TRAVA: cada chave só existe UMA vez por workflow (impede duplicação silenciosa)
  @@unique([workflowId, key])
}

model PhaseAutomationRule {
  id                 Int      @id @default(autoincrement())
  templateId         Int?     // → ModeloAutomacao (solto; null = regra ad-hoc)
  tipoProcessoId     Int      // → TipoProcessoNacionalidade (solto) — regra pertence a um processo
  phaseKey           String   @db.VarChar(60)
  name               String   @db.VarChar(200)
  description        String?  @db.Text
  kind               String   @db.VarChar(30)   // task | financial | document | event | protocol | phase_advance | alert
  scope              String   @default("phase") @db.VarChar(40)
  trigger            String   @default("phase_entered") @db.VarChar(60)
  action             String?  @db.VarChar(80)
  conditions         Json?    // [{ field, op, value }]
  params             Json?    // blob específico do tipo (owner/priority/slaDays/checklist, amount/currency, targetPhaseKey, ...)
  financialType      String?  @db.VarChar(20)   // atalho p/ card/consulta (kind=financial)
  idempotencyPattern String   @default("processId+phaseKey") @db.VarChar(120)
  idempotent         Boolean  @default(true)
  active             Boolean  @default(true)
  arquivado          Boolean  @default(false)

  // --- execução (Fase 4 — guardado, fica zerado por ora) ---
  runCount           Int       @default(0)
  lastRunAt          DateTime?
  lastError          String?   @db.Text

  criadoEm           DateTime @default(now())
  atualizadoEm       DateTime @updatedAt

  @@index([tipoProcessoId])
  @@index([phaseKey])
  @@index([kind])
}

model PhaseTriggerRule {
  id                       Int      @id @default(autoincrement())
  itemCode                 String   @db.VarChar(60)   // → ProdutoFinanceiro.codigo (solto)
  financialItemId          Int?     // → ProdutoFinanceiro.id (solto)
  name                     String   @db.VarChar(200)  // "<item> · <fase>" (calculado)
  phaseKey                 String   @db.VarChar(60)
  phaseEvent               String   @default("entered") @db.VarChar(20)   // entered | completed | reopened | blocked
  entryType                String   @default("revenue") @db.VarChar(20)   // revenue | cost
  automatic                Boolean  @default(true)     // Sim | Não (só sugestão)
  requiresContractSigned   Boolean  @default(false)
  requiresProposalApproved Boolean  @default(false)
  allowRepeat              Boolean  @default(false)
  active                   Boolean  @default(true)
  arquivado                Boolean  @default(false)
  criadoEm                 DateTime @default(now())
  atualizadoEm             DateTime @updatedAt

  @@index([phaseKey])
  @@index([itemCode])
}

model Departamento {
