// Schema atualizado - Processo (cards Kanban) e Tarefa (afazeres) separados
// Contratante e Requerente com campos expandidos
// ✅ ATUALIZAÇÃO: Campos de cidadania + modelo Documento
// ✅ ATUALIZAÇÃO: Subtarefas com auto-relacionamento
// ✅ ATUALIZAÇÃO: Protocolo para processos da Espanha
// ✅ ATUALIZAÇÃO: TipoServico e CustoPessoa para tabela de custos
// ✅ ATUALIZAÇÃO: Campo país e estado expandido para endereços internacionais
// ✅ ATUALIZAÇÃO: Campos passaporte e crnm em Contratante e Requerente

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("PRISMA_DATABASE_URL")
}

// ========================================
// ENUMS
// ========================================
enum Pais {
  PORTUGAL
  ESPANHA
  ALEMANHA
  ITALIA
}

enum PrioridadeTarefa {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

// ✅ NOVO: Consulados da Espanha no Brasil
enum Consulado {
  SAO_PAULO
  PORTO_ALEGRE
  RIO_DE_JANEIRO
  SALVADOR
  BRASILIA
  OUTROS
}

enum Tribunal {
  ANCONA
  BARI
  BOLOGNA
  BRESCIA
  CAGLIARI
  CALTANISSETTA
  CAMPOBASSO
  CATANIA
  CATANZARO
  FIRENZE
  GENOVA
  L_AQUILA
  LECCE
  MESSINA
  MILANO
  NAPOLI
  PALERMO
  PERUGIA
  POTENZA
  REGGIO_CALABRIA
  ROMA
  SALERNO
  TORINO
  TRENTO
  TRIESTE
  VENEZIA
}

// ✅ NOVO: Tipos de documento para cidadania
enum TipoDocumento {
  // Certidões
  CERTIDAO_NASCIMENTO
  CERTIDAO_NASCIMENTO_INTEIRO_TEOR
  CERTIDAO_CASAMENTO
  CERTIDAO_CASAMENTO_INTEIRO_TEOR
  CERTIDAO_OBITO
  CERTIDAO_OBITO_INTEIRO_TEOR
  CERTIDAO_BATISMO
  
  // Documentos específicos de cidadania
  CNN                              // Certidão Negativa de Naturalização
  CARTA_NATURALIZACAO
  
  // Documentos de identidade BR
  RG
  CPF
  CNH
  PASSAPORTE_BRASILEIRO
  TITULO_ELEITOR
  RESERVISTA
  
  // Documentos estrangeiros
  PASSAPORTE_ESTRANGEIRO
  CERTIDAO_CIDADANIA_ESTRANGEIRA
  
  // Comprovantes
  COMPROVANTE_RESIDENCIA
  
  // Tradução e apostilamento
  TRADUCAO_JURAMENTADA
  APOSTILA_HAIA
  
  // Outros
  FOTO_3X4
  PROCURACAO
  ARVORE_GENEALOGICA_DOC
  OUTRO
}

// ✅ NOVO: Status do documento no processo
enum StatusDocumento {
  PENDENTE
  SOLICITADO
  EM_BUSCA
  RECEBIDO
  EM_ANALISE
  RETIFICANDO
  EM_TRADUCAO
  TRADUZIDO
  EM_APOSTILAMENTO
  APOSTILADO
  ENTREGUE
  INVALIDO
  NAO_ENCONTRADO
}

// ========================================
// USUÁRIOS
// ========================================
model Usuario {
  id    Int    @id @default(autoincrement())
  nome  String @db.VarChar(100)
  email String @unique @db.VarChar(100)
  senha String @db.VarChar(255)
  tipo  String @db.VarChar(20)

  // Tarefas atribuídas ao usuário
  tarefas Tarefa[]
  
  // Logs de auditoria
  logs LogAuditoria[]
}

// ========================================
// ÁRVORE GENEALÓGICA - PESSOA
// ========================================
model Pessoa {
  id         Int       @id @default(autoincrement())
  nome       String    @db.VarChar(50)
  sobrenome  String?   @db.VarChar(40)
  sexo       String?   @db.VarChar(10)
  data_nasc  DateTime?
  data_obito DateTime?
  
  // Local de nascimento (✅ EXPANDIDO)
  local_nasc      String?   @db.VarChar(100)  // Cidade (aumentado de 30 para 100)
  estado_nasc     String?   @db.VarChar(50)   // ✅ NOVO: Estado/Província  
  pais_nasc       String?   @db.VarChar(50)   // ✅ NOVO: País - IMPORTANTE para cidadania
  
  // ✅ NOVO: Status vital explícito
  vivo            Boolean   @default(true)
  
  // Batismo (✅ EXPANDIDO)
  batizado        String?   @db.VarChar(50)   // Aumentado de 10 para 50
  data_batismo    DateTime?                    // ✅ NOVO
  local_batismo   String?   @db.VarChar(100)  // ✅ NOVO: Cidade do batismo
  igreja_batismo  String?   @db.VarChar(150)  // ✅ NOVO: Nome da igreja/paróquia
  
  // ✅ NOVO: Profissão
  profissao       String?   @db.VarChar(100)
  
  // ✅ NOVO: Nacionalidade e Cidadania
  nacionalidade       String?   @db.VarChar(50)   // Nacionalidade principal
  cidadanias_outras   String?   @db.VarChar(200)  // Outras cidadanias (separadas por vírgula)
  
  // ✅ NOVO: Naturalização (pode impedir cidadania por descendência)
  naturalizado            Boolean   @default(false)
  data_naturalizacao      DateTime?
  pais_naturalizacao      String?   @db.VarChar(50)
  
  // ✅ NOVO: Emigração/Imigração (importante para rastrear linhagem)
  data_emigracao      DateTime?
  local_emigracao     String?   @db.VarChar(100)  // Cidade de onde emigrou
  porto_embarque      String?   @db.VarChar(100)
  data_chegada        DateTime?
  porto_chegada       String?   @db.VarChar(100)
  pais_destino        String?   @db.VarChar(50)
  navio               String?   @db.VarChar(100)
  
  // Notas
  comentario  String?   @db.Text
  
  // Posição no canvas (React Flow)
  x Int?
  y Int?

  // Relacionamentos existentes
  arvoreId Int
  arvore   Arvore @relation("PessoasNaArvore", fields: [arvoreId], references: [id], onDelete: Cascade)

  paiId Int?
  pai   Pessoa? @relation("FilhosPai", fields: [paiId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  maeId Int?
  mae   Pessoa? @relation("FilhosMae", fields: [maeId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  filhosComoPai Pessoa[] @relation("FilhosPai")
  filhosComoMae Pessoa[] @relation("FilhosMae")

  unioesComoPessoa1 Uniao[] @relation("Pessoa1")
  unioesComoPessoa2 Uniao[] @relation("Pessoa2")

  arvorePrincipal Arvore? @relation("ArvorePrincipal")
  
  // ✅ NOVO: Relacionamento com documentos
  documentos Documento[]
  
  // ✅ NOVO: Custos vinculados à pessoa
  custos CustoPessoa[]
  
  // ✅ NOVO: Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([arvoreId])
  @@index([pais_nasc])
}

// ========================================
// ÁRVORE GENEALÓGICA - UNIÃO/CASAMENTO
// ========================================
model Uniao {
  id          Int       @id @default(autoincrement())
  data_inicio DateTime?
  data_fim    DateTime?
  tipo        String?   @db.VarChar(30)   // Aumentado de 10 para 30
  
  // Local do casamento (✅ EXPANDIDO)
  local       String?   @db.VarChar(100)  // Cidade
  estado      String?   @db.VarChar(50)   // ✅ NOVO: Estado/Província
  pais        String?   @db.VarChar(50)   // ✅ NOVO: País
  
  // ✅ NOVO: Dados da certidão de casamento
  cartorio            String?   @db.VarChar(200)
  livro               String?   @db.VarChar(20)
  folha               String?   @db.VarChar(20)
  termo               String?   @db.VarChar(30)
  numero_registro     String?   @db.VarChar(50)
  data_registro       DateTime?
  
  // ✅ NOVO: Observações
  observacoes String?   @db.Text

  pessoa1Id Int
  pessoa1   Pessoa @relation("Pessoa1", fields: [pessoa1Id], references: [id], onDelete: Cascade)

  pessoa2Id Int
  pessoa2   Pessoa @relation("Pessoa2", fields: [pessoa2Id], references: [id], onDelete: Cascade)
  
  // ✅ NOVO: Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([pessoa1Id])
  @@index([pessoa2Id])
}

// ========================================
// ÁRVORE GENEALÓGICA - ÁRVORE
// ========================================
model Arvore {
  id        Int     @id @default(autoincrement())
  nome      String  @db.VarChar(50)
  descricao String? @db.VarChar(200)

  commentPosX Float? @default(0)
  commentPosY Float? @default(0)

  pessoaPrincipalId Int?    @unique
  pessoaPrincipal   Pessoa? @relation("ArvorePrincipal", fields: [pessoaPrincipalId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  pessoas   Pessoa[]   @relation("PessoasNaArvore")
  processos Processo[]
}

// ========================================
// ✅ NOVO: DOCUMENTO (certidões, RG, passaporte, etc)
// ========================================
model Documento {
  id          Int       @id @default(autoincrement())
  
  // Pessoa vinculada
  pessoaId    Int
  pessoa      Pessoa    @relation(fields: [pessoaId], references: [id], onDelete: Cascade)
  
  // Tipo e status
  tipo        TipoDocumento
  status      StatusDocumento @default(PENDENTE)
  descricao   String?   @db.VarChar(200)
  
  // Dados do registro (para certidões)
  cartorio            String?   @db.VarChar(200)
  livro               String?   @db.VarChar(20)
  folha               String?   @db.VarChar(20)
  termo               String?   @db.VarChar(30)
  numero_registro     String?   @db.VarChar(50)
  data_registro       DateTime?
  cidade_registro     String?   @db.VarChar(100)
  estado_registro     String?   @db.VarChar(50)
  pais_registro       String?   @db.VarChar(50)
  
  // Para documentos de identidade
  numero              String?   @db.VarChar(50)
  orgao_emissor       String?   @db.VarChar(50)
  data_emissao        DateTime?
  data_validade       DateTime?
  
  // Arquivo digitalizado
  arquivo_url         String?   @db.Text
  arquivo_nome        String?   @db.VarChar(200)
  arquivo_tamanho     Int?
  arquivo_mime_type   String?   @db.VarChar(100)
  
  // Tradução
  traduzido                   Boolean   @default(false)
  tradutor                    String?   @db.VarChar(150)
  data_traducao               DateTime?
  arquivo_traducao_url        String?   @db.Text
  arquivo_traducao_nome       String?   @db.VarChar(200)
  
  // Apostilamento (Convenção de Haia)
  apostilado                  Boolean   @default(false)
  numero_apostila             String?   @db.VarChar(50)
  data_apostila               DateTime?
  arquivo_apostila_url        String?   @db.Text
  
  // Observações
  observacoes         String?   @db.Text
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([pessoaId])
  @@index([tipo])
  @@index([status])
}

// ========================================
// STATUS - ETAPAS DAS TAREFAS
// ========================================
model Status {
  id    Int    @id @default(autoincrement())
  nome  String @db.VarChar(50)
  ordem Int    @default(0)

  pais Pais

  processos Processo[]
  
  // ✅ NOVO: Tarefas vinculadas ao status
  tarefas Tarefa[]

  @@unique([nome, pais])
  @@index([pais])
}

// ========================================
// PROCESSO - CARD DO KANBAN (FAMÍLIA)
// Representa uma família no processo de cidadania
// ========================================
model Processo {
  id           Int       @id @default(autoincrement())
  nome         String    @db.VarChar(100)
  descricao    String?   @db.VarChar(500)
  observacoes  String?   @db.Text
  faturas Fatura[]
  
  pais         Pais
  
  statusId     Int
  status       Status    @relation(fields: [statusId], references: [id], onDelete: Cascade)
  
  contratantes ProcessoContratante[]
  
  arvoreId     Int?
  arvore       Arvore?   @relation(fields: [arvoreId], references: [id], onDelete: SetNull)
  
  dataInicio   DateTime  @default(now())
  previsaoTermino DateTime?
  dataConclusao DateTime?
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  requerentes  ProcessoRequerente[]
  tarefas      Tarefa[]
  anexos       AnexoProcesso[]
  
  // ✅ NOVO: Protocolos (apenas para Espanha)
  protocolos   Protocolo[]
  informacaoItalia InformacaoItalia?
  
  // ✅ NOVO: Tipos de serviço e custos por pessoa
  tiposServico TipoServico[]
  custosPessoa CustoPessoa[]
  
  @@index([pais])
  @@index([statusId])
}

// ========================================
// RELACIONAMENTO PROCESSO <-> CONTRATANTE
// ========================================
model ProcessoContratante {
  processoId    Int
  contratanteId Int
  processo      Processo    @relation(fields: [processoId], references: [id], onDelete: Cascade)
  contratante   Contratante @relation(fields: [contratanteId], references: [id], onDelete: Cascade)

  @@id([processoId, contratanteId])
}

// ========================================
// TAREFA - AFAZERES (COM SUPORTE A SUBTAREFAS)
// ========================================
model Tarefa {
  id          Int       @id @default(autoincrement())
  titulo      String    @db.VarChar(200)
  descricao   String?   @db.Text
  
  // ✅ Vínculo opcional com processo (tarefa pode existir independente)
  processoId  Int?
  processo    Processo?  @relation(fields: [processoId], references: [id], onDelete: Cascade)
  
  // ✅ NOVO: Vínculo com status
  statusId    Int?
  status      Status?   @relation(fields: [statusId], references: [id], onDelete: SetNull)
  
  // ✅ NOVO: País da tarefa (para tarefas independentes)
  pais        Pais?
  
  responsavelId Int?
  responsavel   Usuario? @relation(fields: [responsavelId], references: [id], onDelete: SetNull)
  
  concluida   Boolean   @default(false)
  prioridade  PrioridadeTarefa @default(MEDIA)
  
  dataPrazo   DateTime?
  dataConclusao DateTime?
  
  // ✅ NOVO: Auto-relacionamento para subtarefas
  // Uma tarefa pode ter uma tarefa pai (ser subtarefa)
  tarefaPaiId Int?
  tarefaPai   Tarefa?  @relation("Subtarefas", fields: [tarefaPaiId], references: [id], onDelete: Cascade)
  
  // Uma tarefa pode ter várias subtarefas
  subtarefas  Tarefa[] @relation("Subtarefas")
  
  // ✅ NOVO: Ordem da tarefa/subtarefa para organização
  ordem       Int      @default(0)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([processoId])
  @@index([responsavelId])
  @@index([concluida])
  @@index([tarefaPaiId])
  @@index([statusId])
  @@index([pais])
}

// ========================================
// RELACIONAMENTO PROCESSO <-> REQUERENTE
// ========================================
model ProcessoRequerente {
  processoId   Int
  requerenteId Int
  processo     Processo   @relation(fields: [processoId], references: [id], onDelete: Cascade)
  requerente   Requerente @relation(fields: [requerenteId], references: [id], onDelete: Cascade)

  @@id([processoId, requerenteId])
}

// ========================================
// CONTRATANTE - CLIENTE QUE CONTRATA
// ✅ ATUALIZAÇÃO: Campo país + estado expandido para endereços internacionais
// ========================================
model Contratante {
  id              Int       @id @default(autoincrement())
  nome            String    @db.VarChar(100)
  cpf             String?   @db.VarChar(14)
  rg              String?   @db.VarChar(20)
  passaporte      String?   @db.VarChar(20)  // ✅ NOVO
  crnm            String?   @db.VarChar(20)  // ✅ NOVO: Carteira de Registro Nacional Migratório
  dataNascimento  DateTime?
  sexo            String?   @db.VarChar(20)
  estadoCivil     String?   @db.VarChar(20)
  nacionalidade   String?   @db.VarChar(50)
  telefone        String?   @db.VarChar(20)
  email           String?   @db.VarChar(100)
  
  // ✅ ATUALIZAÇÃO: Endereço com suporte internacional
  pais            String?   @db.VarChar(50) @default("Brasil")  // ✅ NOVO
  endereco        String?   @db.VarChar(200)
  numero          String?   @db.VarChar(20)
  complemento     String?   @db.VarChar(100)
  bairro          String?   @db.VarChar(100)
  cidade          String?   @db.VarChar(100)
  estado          String?   @db.VarChar(50)  // ✅ EXPANDIDO: de 2 para 50 (aceita estados/províncias internacionais)
  cep             String?   @db.VarChar(15)  // ✅ EXPANDIDO: de 10 para 15 (aceita códigos postais internacionais)
  
  observacoes     String?   @db.Text
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  processos       ProcessoContratante[]
  anexos          AnexoContratante[]
  
  // ✅ NOVO: Protocolos vinculados
  protocolos      Protocolo[]
}

// ========================================
// REQUERENTE - QUEM VAI RECEBER CIDADANIA
// ✅ ATUALIZAÇÃO: Campo país + estado expandido para endereços internacionais
// ========================================
model Requerente {
  id              Int       @id @default(autoincrement())
  nome            String    @db.VarChar(100)
  cpf             String?   @db.VarChar(14)
  rg              String?   @db.VarChar(20)
  passaporte      String?   @db.VarChar(20)  // ✅ NOVO
  crnm            String?   @db.VarChar(20)  // ✅ NOVO: Carteira de Registro Nacional Migratório
  dataNascimento  DateTime?
  sexo            String?   @db.VarChar(20)
  estadoCivil     String?   @db.VarChar(20)
  nacionalidade   String?   @db.VarChar(50)
  telefone        String?   @db.VarChar(20)
  email           String?   @db.VarChar(100)
  
  // ✅ ATUALIZAÇÃO: Endereço com suporte internacional
  pais            String?   @db.VarChar(50) @default("Brasil")  // ✅ NOVO
  endereco        String?   @db.VarChar(200)
  numero          String?   @db.VarChar(20)
  complemento     String?   @db.VarChar(100)
  bairro          String?   @db.VarChar(100)
  cidade          String?   @db.VarChar(100)
  estado          String?   @db.VarChar(50)  // ✅ EXPANDIDO: de 2 para 50 (aceita estados/províncias internacionais)
  cep             String?   @db.VarChar(15)  // ✅ EXPANDIDO: de 10 para 15 (aceita códigos postais internacionais)
  
  observacoes     String?   @db.Text
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  processos       ProcessoRequerente[]
  anexos          AnexoRequerente[]
  
  // ✅ NOVO: Protocolos vinculados
  protocolos      Protocolo[]
}

// ========================================
// ✅ NOVO: PROTOCOLO - APENAS PARA ESPANHA
// ========================================
model Protocolo {
  id              Int       @id @default(autoincrement())
  
  // Vínculo com processo
  processoId      Int
  processo        Processo  @relation(fields: [processoId], references: [id], onDelete: Cascade)
  
  // Pessoa vinculada (pode ser contratante OU requerente)
  contratanteId   Int?
  contratante     Contratante? @relation(fields: [contratanteId], references: [id], onDelete: Cascade)
  
  requerenteId    Int?
  requerente      Requerente? @relation(fields: [requerenteId], references: [id], onDelete: Cascade)
  
  // Dados do protocolo
  consulado       Consulado
  consuladoOutro  String?   @db.VarChar(200) // Se consulado = OUTROS
  
  dataProtocolo   DateTime?
  numeroProtocolo String?   @db.VarChar(100)
  
  observacoes     String?   @db.Text
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // ✅ NOVO: Anexos do protocolo
  anexos          AnexoProtocolo[]

  @@index([processoId])
  @@index([contratanteId])
  @@index([requerenteId])
}

model InformacaoItalia {
  id              Int       @id @default(autoincrement())
  
  // Vínculo com processo (1 processo = 1 informação)
  processoId      Int       @unique
  processo        Processo  @relation(fields: [processoId], references: [id], onDelete: Cascade)
  
  // Dados do tribunal
  tribunal        Tribunal
  
  // Datas
  dataProtocolo     DateTime?
  dataDistribuicao  DateTime?
  
  // Número do processo
  numeroRuoloGenerale String?   @db.VarChar(100)
  
  // Observações
  observacoes     String?   @db.Text
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Anexos
  anexos          AnexoInformacaoItalia[]

  @@index([processoId])
}

model AnexoInformacaoItalia {
  id                  Int      @id @default(autoincrement())
  nome                String   @db.VarChar(200)
  tipo                String?  @db.VarChar(50)
  nomeArquivo         String   @db.VarChar(300)
  urlArquivo          String   @db.Text
  tamanho             Int?
  mimeType            String?  @db.VarChar(100)
  
  informacaoItaliaId  Int
  informacaoItalia    InformacaoItalia @relation(fields: [informacaoItaliaId], references: [id], onDelete: Cascade)
  
  createdAt           DateTime @default(now())

  @@index([informacaoItaliaId])
}

// ========================================
// ANEXOS
// ========================================
model AnexoProcesso {
  id            Int      @id @default(autoincrement())
  nome          String   @db.VarChar(200)
  tipo          String   @db.VarChar(50)
  nomeArquivo   String   @db.VarChar(300)
  urlArquivo    String   @db.Text
  tamanho       Int?
  mimeType      String?  @db.VarChar(100)
  
  processoId    Int
  processo      Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())

  @@index([processoId])
}

model AnexoContratante {
  id            Int      @id @default(autoincrement())
  nome          String   @db.VarChar(200)
  tipo          String?  @db.VarChar(50)
  nomeArquivo   String   @db.VarChar(300)
  urlArquivo    String   @db.Text
  tamanho       Int?
  mimeType      String?  @db.VarChar(100)
  
  contratanteId Int
  contratante   Contratante @relation(fields: [contratanteId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())

  @@index([contratanteId])
}

model AnexoRequerente {
  id            Int      @id @default(autoincrement())
  nome          String   @db.VarChar(200)
  tipo          String?  @db.VarChar(50)
  nomeArquivo   String   @db.VarChar(300)
  urlArquivo    String   @db.Text
  tamanho       Int?
  mimeType      String?  @db.VarChar(100)
  
  requerenteId  Int
  requerente    Requerente @relation(fields: [requerenteId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())

  @@index([requerenteId])
}

// ========================================
// ANEXO DE PROTOCOLO
// ========================================
model AnexoProtocolo {
  id            Int      @id @default(autoincrement())
  nome          String   @db.VarChar(200)
  tipo          String?  @db.VarChar(50)
  nomeArquivo   String   @db.VarChar(300)
  urlArquivo    String   @db.Text
  tamanho       Int?
  mimeType      String?  @db.VarChar(100)
  
  protocoloId   Int
  protocolo     Protocolo @relation(fields: [protocoloId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())

  @@index([protocoloId])
}

// ========================================
// LOG DE AUDITORIA
// ========================================
model LogAuditoria {
  id          Int      @id @default(autoincrement())
  acao        String   @db.VarChar(50)
  entidade    String   @db.VarChar(50)
  entidadeId  Int?
  descricao   String   @db.Text
  detalhes    Json?
  
  usuarioId   Int?
  usuario     Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  
  criadoEm    DateTime @default(now())

  @@index([entidade])
  @@index([usuarioId])
  @@index([criadoEm])
}

// ========================================
// FATURA - COBRANÇA POR PROCESSO
// ========================================
enum StatusFatura {
  PENDENTE
  PAGO
  VENCIDO
  CANCELADO
  PARCIAL
}

enum FormaPagamento {
  PIX
  CARTAO_CREDITO
  CARTAO_DEBITO
  BOLETO
  TRANSFERENCIA
  DINHEIRO
  CHEQUE
  OUTRO
}

model Fatura {
  id              Int           @id @default(autoincrement())
  
  // Vínculo com processo
  processoId      Int
  processo        Processo      @relation(fields: [processoId], references: [id], onDelete: Cascade)
  
  // Dados da fatura
  descricao       String        @db.VarChar(200)
  valor           Decimal       @db.Decimal(10, 2)
  status          StatusFatura  @default(PENDENTE)
  
  // Datas
  dataEmissao     DateTime      @default(now())
  dataVencimento  DateTime?
  dataPagamento   DateTime?
  
  // Pagamento
  formaPagamento  FormaPagamento?
  valorPago       Decimal?      @db.Decimal(10, 2)
  
  // Comprovante
  comprovanteUrl  String?       @db.Text
  comprovanteNome String?       @db.VarChar(200)
  
  // Observações
  observacoes     String?       @db.Text
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([processoId])
  @@index([status])
  @@index([dataVencimento])
}

// ========================================
// TIPO DE SERVIÇO - COLUNAS DE CUSTO POR PROCESSO
// ========================================
model TipoServico {
  id          Int       @id @default(autoincrement())
  
  // Vínculo com processo
  processoId  Int
  processo    Processo  @relation(fields: [processoId], references: [id], onDelete: Cascade)
  
  // Dados do tipo de serviço
  nome        String    @db.VarChar(100)  // Ex: "Certidão Inteiro Teor", "Tradução", etc.
  ordem       Int       @default(0)        // Ordem de exibição na tabela
  
  createdAt   DateTime  @default(now())
  
  // Custos vinculados
  custos      CustoPessoa[]

  @@index([processoId])
}

// ========================================
// CUSTO POR PESSOA - VALORES DA PLANILHA
// ========================================
model CustoPessoa {
  id              Int       @id @default(autoincrement())
  
  // Vínculos
  processoId      Int
  processo        Processo      @relation(fields: [processoId], references: [id], onDelete: Cascade)
  
  pessoaId        Int
  pessoa          Pessoa        @relation(fields: [pessoaId], references: [id], onDelete: Cascade)
  
  tipoServicoId   Int
  tipoServico     TipoServico   @relation(fields: [tipoServicoId], references: [id], onDelete: Cascade)
  
  // Valor
  valor           Decimal       @db.Decimal(10, 2) @default(0)
  observacao      String?       @db.VarChar(200)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Constraint único: uma pessoa só pode ter um valor por tipo de serviço no processo
  @@unique([processoId, pessoaId, tipoServicoId])
  @@index([processoId])
  @@index([pessoaId])
  @@index([tipoServicoId])
}

// ========================================
// ADICIONAR AO FINAL DO schema.prisma
// MÓDULO FINANCEIRO COMPLETO
// ========================================

// ========================================
// ENUMS FINANCEIROS
// ========================================

enum TipoTransacao {
  ENTRADA
  SAIDA
}

enum StatusContaPagar {
  PENDENTE
  PAGO
  VENCIDO
  CANCELADO
  AGENDADO
}

enum RecorrenciaTipo {
  UNICA
  SEMANAL
  MENSAL
  TRIMESTRAL
  SEMESTRAL
  ANUAL
}

// ========================================
// CATEGORIA FINANCEIRA
// ========================================
model CategoriaFinanceira {
  id          Int       @id @default(autoincrement())
  nome        String    @db.VarChar(100)
  tipo        TipoTransacao  // ENTRADA ou SAIDA
  cor         String?   @db.VarChar(7)  // Hex color para gráficos
  icone       String?   @db.VarChar(50)
  descricao   String?   @db.VarChar(200)
  
  // Categoria pai (para subcategorias)
  categoriaPaiId Int?
  categoriaPai   CategoriaFinanceira?  @relation("Subcategorias", fields: [categoriaPaiId], references: [id], onDelete: SetNull)
  subcategorias  CategoriaFinanceira[] @relation("Subcategorias")
  
  ativo       Boolean   @default(true)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relacionamentos
  contasPagar ContaPagar[]
  transacoes  Transacao[]

  @@index([tipo])
}

// ========================================
// CONTA BANCÁRIA
// ========================================
model ContaBancaria {
  id              Int       @id @default(autoincrement())
  nome            String    @db.VarChar(100)  // Ex: "Conta Principal", "Caixa"
  banco           String?   @db.VarChar(100)
  agencia         String?   @db.VarChar(20)
  conta           String?   @db.VarChar(30)
  tipoConta       String?   @db.VarChar(30)   // Corrente, Poupança, Caixa
  
  // Chaves Pix
  chavePix        String?   @db.VarChar(100)
  tipoChavePix    String?   @db.VarChar(20)   // CPF, CNPJ, Email, Telefone, Aleatoria
  
  saldoInicial    Decimal   @db.Decimal(12, 2) @default(0)
  saldoAtual      Decimal   @db.Decimal(12, 2) @default(0)
  
  cor             String?   @db.VarChar(7)    // Para identificação visual
  ativo           Boolean   @default(true)
  principal       Boolean   @default(false)   // Conta principal
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relacionamentos
  transacoes      Transacao[]
  contasPagar     ContaPagar[]

  @@index([ativo])
}

// ========================================
// FORNECEDOR
// ========================================
model Fornecedor {
  id              Int       @id @default(autoincrement())
  
  // Dados básicos
  nome            String    @db.VarChar(150)
  nomeFantasia    String?   @db.VarChar(150)
  tipo            String    @db.VarChar(20)   // PF ou PJ
  
  // Documentos
  cpfCnpj         String?   @db.VarChar(20)
  inscricaoEstadual String? @db.VarChar(20)
  inscricaoMunicipal String? @db.VarChar(20)
  
  // Contato
  telefone        String?   @db.VarChar(20)
  celular         String?   @db.VarChar(20)
  email           String?   @db.VarChar(100)
  website         String?   @db.VarChar(200)
  
  // Endereço
  cep             String?   @db.VarChar(10)
  endereco        String?   @db.VarChar(200)
  numero          String?   @db.VarChar(20)
  complemento     String?   @db.VarChar(100)
  bairro          String?   @db.VarChar(100)
  cidade          String?   @db.VarChar(100)
  estado          String?   @db.VarChar(2)
  
  // Dados bancários do fornecedor (para pagamentos)
  banco           String?   @db.VarChar(100)
  agencia         String?   @db.VarChar(20)
  conta           String?   @db.VarChar(30)
  tipoConta       String?   @db.VarChar(20)
  chavePix        String?   @db.VarChar(100)
  tipoChavePix    String?   @db.VarChar(20)
  
  observacoes     String?   @db.Text
  ativo           Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relacionamentos
  contasPagar     ContaPagar[]

  @@index([nome])
  @@index([cpfCnpj])
  @@index([ativo])
}

// ========================================
// CONTA A PAGAR
// ========================================
model ContaPagar {
  id              Int             @id @default(autoincrement())
  
  // Descrição
  descricao       String          @db.VarChar(200)
  observacoes     String?         @db.Text
  
  // Fornecedor (opcional - pode ser despesa sem fornecedor)
  fornecedorId    Int?
  fornecedor      Fornecedor?     @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)
  
  // Categoria
  categoriaId     Int?
  categoria       CategoriaFinanceira? @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  
  // Valores
  valor           Decimal         @db.Decimal(12, 2)
  valorPago       Decimal?        @db.Decimal(12, 2)
  desconto        Decimal?        @db.Decimal(12, 2) @default(0)
  juros           Decimal?        @db.Decimal(12, 2) @default(0)
  multa           Decimal?        @db.Decimal(12, 2) @default(0)
  
  // Datas
  dataEmissao     DateTime        @default(now())
  dataVencimento  DateTime
  dataPagamento   DateTime?
  dataCompetencia DateTime?       // Mês de competência contábil
  
  // Status
  status          StatusContaPagar @default(PENDENTE)
  
  // Pagamento
  formaPagamento  FormaPagamento?
  contaBancariaId Int?
  contaBancaria   ContaBancaria?  @relation(fields: [contaBancariaId], references: [id], onDelete: SetNull)
  
  // Documento fiscal
  numeroDocumento String?         @db.VarChar(50)
  tipoDocumento   String?         @db.VarChar(50)  // NF, Boleto, Recibo, etc
  
  // Comprovante
  comprovanteUrl  String?         @db.Text
  comprovanteNome String?         @db.VarChar(200)
  
  // Recorrência
  recorrencia     RecorrenciaTipo @default(UNICA)
  contaPaiId      Int?            // Se for parcela de uma conta parcelada
  numeroParcela   Int?
  totalParcelas   Int?
  
  // Vínculo com processo (opcional)
  processoId      Int?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Transação gerada quando pago
  transacoes      Transacao[]

  @@index([fornecedorId])
  @@index([categoriaId])
  @@index([status])
  @@index([dataVencimento])
  @@index([processoId])
}

// ========================================
// TRANSAÇÃO (FLUXO DE CAIXA)
// ========================================
model Transacao {
  id              Int             @id @default(autoincrement())
  
  // Tipo e descrição
  tipo            TipoTransacao
  descricao       String          @db.VarChar(200)
  observacoes     String?         @db.Text
  
  // Valores
  valor           Decimal         @db.Decimal(12, 2)
  
  // Data
  data            DateTime        @default(now())
  dataCompetencia DateTime?       // Mês de competência
  
  // Conta bancária
  contaBancariaId Int
  contaBancaria   ContaBancaria   @relation(fields: [contaBancariaId], references: [id], onDelete: Restrict)
  
  // Categoria
  categoriaId     Int?
  categoria       CategoriaFinanceira? @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  
  // Origem da transação (qual entidade gerou)
  // Pode ser uma fatura paga (entrada) ou conta paga (saída)
  faturaId        Int?
  contaPagarId    Int?
  contaPagar      ContaPagar?     @relation(fields: [contaPagarId], references: [id], onDelete: SetNull)
  
  // Vínculo com processo
  processoId      Int?
  
  // Conciliação bancária
  conciliado      Boolean         @default(false)
  dataConciliacao DateTime?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([tipo])
  @@index([contaBancariaId])
  @@index([categoriaId])
  @@index([data])
  @@index([faturaId])
  @@index([contaPagarId])
  @@index([processoId])
}

// ========================================
// CENTRO DE CUSTO (OPCIONAL - PARA ANÁLISE)
// ========================================
model CentroCusto {
  id          Int       @id @default(autoincrement())
  nome        String    @db.VarChar(100)
  descricao   String?   @db.VarChar(200)
  cor         String?   @db.VarChar(7)
  ativo       Boolean   @default(true)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([ativo])
}