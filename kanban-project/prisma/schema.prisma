// Schema atualizado - Processo (cards Kanban) e Tarefa (afazeres) separados
// Contratante e Requerente com campos expandidos

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("PRISMA_DATABASE_URL")
}

// ========================================
// ENUMS
// ========================================
enum Pais {
  PORTUGAL
  ESPANHA
  ALEMANHA
  ITALIA
}

enum PrioridadeTarefa {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

// ========================================
// USUÁRIOS
// ========================================
model Usuario {
  id    Int    @id @default(autoincrement())
  nome  String @db.VarChar(50)
  email String @unique @db.VarChar(30)
  senha String @db.VarChar(255)
  tipo  String @db.VarChar(15)

  // Tarefas atribuídas ao usuário
  tarefas Tarefa[]
  
  // Logs de auditoria
  logs LogAuditoria[]
}

// ========================================
// ÁRVORE GENEALÓGICA
// ========================================
model Pessoa {
  id         Int       @id @default(autoincrement())
  nome       String    @db.VarChar(50)
  sobrenome  String?   @db.VarChar(40)
  sexo       String?   @db.VarChar(10)
  data_nasc  DateTime?
  local_nasc String?   @db.VarChar(30)
  data_obito DateTime?
  batizado   String?   @db.VarChar(10)
  comentario String?   @db.Text

  x Int?
  y Int?

  arvoreId Int
  arvore   Arvore @relation("PessoasNaArvore", fields: [arvoreId], references: [id], onDelete: Cascade)

  paiId Int?
  pai   Pessoa? @relation("FilhosPai", fields: [paiId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  maeId Int?
  mae   Pessoa? @relation("FilhosMae", fields: [maeId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  filhosComoPai Pessoa[] @relation("FilhosPai")
  filhosComoMae Pessoa[] @relation("FilhosMae")

  unioesComoPessoa1 Uniao[] @relation("Pessoa1")
  unioesComoPessoa2 Uniao[] @relation("Pessoa2")

  arvorePrincipal Arvore? @relation("ArvorePrincipal")
}

model Uniao {
  id          Int       @id @default(autoincrement())
  data_inicio DateTime?
  data_fim    DateTime?
  tipo        String?   @db.VarChar(10)
  local       String?

  pessoa1Id Int
  pessoa1   Pessoa @relation("Pessoa1", fields: [pessoa1Id], references: [id], onDelete: Cascade)

  pessoa2Id Int
  pessoa2   Pessoa @relation("Pessoa2", fields: [pessoa2Id], references: [id], onDelete: Cascade)
}

model Arvore {
  id        Int     @id @default(autoincrement())
  nome      String  @db.VarChar(50)
  descricao String? @db.VarChar(200)

  commentPosX Float? @default(0)
  commentPosY Float? @default(0)

  pessoaPrincipalId Int?    @unique
  pessoaPrincipal   Pessoa? @relation("ArvorePrincipal", fields: [pessoaPrincipalId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  pessoas   Pessoa[]   @relation("PessoasNaArvore")
  processos Processo[]
}

// ========================================
// STATUS - ETAPAS DO KANBAN POR PAÍS
// ========================================
model Status {
  id    Int    @id @default(autoincrement())
  nome  String @db.VarChar(50)
  ordem Int    @default(0)

  pais Pais

  processos Processo[]

  @@unique([nome, pais])
  @@index([pais])
}

// ========================================
// PROCESSO - CARD DO KANBAN (FAMÍLIA)
// Representa uma família no processo de cidadania
// ========================================
model Processo {
  id           Int       @id @default(autoincrement())
  nome         String    @db.VarChar(100)
  descricao    String?   @db.VarChar(500)
  observacoes  String?   @db.Text
  
  pais         Pais
  
  statusId     Int
  status       Status    @relation(fields: [statusId], references: [id], onDelete: Cascade)
  
  contratantes ProcessoContratante[]
  
  arvoreId     Int?
  arvore       Arvore?   @relation(fields: [arvoreId], references: [id], onDelete: SetNull)
  
  dataInicio   DateTime  @default(now())
  previsaoTermino DateTime?
  dataConclusao DateTime?
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  requerentes  ProcessoRequerente[]
  tarefas      Tarefa[]
  anexos       AnexoProcesso[]

  @@index([pais])
  @@index([statusId])
}

// ========================================
// RELACIONAMENTO PROCESSO <-> CONTRATANTE
// ========================================
model ProcessoContratante {
  processoId    Int
  contratanteId Int
  processo      Processo    @relation(fields: [processoId], references: [id], onDelete: Cascade)
  contratante   Contratante @relation(fields: [contratanteId], references: [id], onDelete: Cascade)

  @@id([processoId, contratanteId])
}

// ========================================
// TAREFA - AFAZERES DOS FUNCIONÁRIOS
// ========================================
model Tarefa {
  id          Int       @id @default(autoincrement())
  titulo      String    @db.VarChar(200)
  descricao   String?   @db.Text
  
  processoId  Int
  processo    Processo  @relation(fields: [processoId], references: [id], onDelete: Cascade)
  
  responsavelId Int?
  responsavel   Usuario? @relation(fields: [responsavelId], references: [id], onDelete: SetNull)
  
  concluida   Boolean   @default(false)
  prioridade  PrioridadeTarefa @default(MEDIA)
  
  dataPrazo   DateTime?
  dataConclusao DateTime?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([processoId])
  @@index([responsavelId])
  @@index([concluida])
}

// ========================================
// RELACIONAMENTO PROCESSO <-> REQUERENTE
// ========================================
model ProcessoRequerente {
  processoId   Int
  requerenteId Int
  processo     Processo   @relation(fields: [processoId], references: [id], onDelete: Cascade)
  requerente   Requerente @relation(fields: [requerenteId], references: [id], onDelete: Cascade)

  @@id([processoId, requerenteId])
}

// ========================================
// CONTRATANTE - CLIENTE QUE CONTRATA
// ========================================
model Contratante {
  id              Int       @id @default(autoincrement())
  nome            String    @db.VarChar(100)
  cpf             String?   @db.VarChar(14)
  rg              String?   @db.VarChar(20)
  dataNascimento  DateTime?
  sexo            String?   @db.VarChar(20)
  estadoCivil     String?   @db.VarChar(20)
  nacionalidade   String?   @db.VarChar(50)
  telefone        String?   @db.VarChar(20)
  email           String?   @db.VarChar(100)
  
  endereco        String?   @db.VarChar(200)
  numero          String?   @db.VarChar(20)
  complemento     String?   @db.VarChar(100)
  bairro          String?   @db.VarChar(100)
  cidade          String?   @db.VarChar(100)
  estado          String?   @db.VarChar(2)
  cep             String?   @db.VarChar(10)
  
  observacoes     String?   @db.Text
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  processos       ProcessoContratante[]
  anexos          AnexoContratante[]
}

// ========================================
// REQUERENTE - QUEM VAI RECEBER CIDADANIA
// ========================================
model Requerente {
  id              Int       @id @default(autoincrement())
  nome            String    @db.VarChar(100)
  cpf             String?   @db.VarChar(14)
  rg              String?   @db.VarChar(20)
  dataNascimento  DateTime?
  sexo            String?   @db.VarChar(20)
  estadoCivil     String?   @db.VarChar(20)
  nacionalidade   String?   @db.VarChar(50)
  telefone        String?   @db.VarChar(20)
  email           String?   @db.VarChar(100)
  
  endereco        String?   @db.VarChar(200)
  numero          String?   @db.VarChar(20)
  complemento     String?   @db.VarChar(100)
  bairro          String?   @db.VarChar(100)
  cidade          String?   @db.VarChar(100)
  estado          String?   @db.VarChar(2)
  cep             String?   @db.VarChar(10)
  
  observacoes     String?   @db.Text
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  processos       ProcessoRequerente[]
  anexos          AnexoRequerente[]
}

// ========================================
// ANEXOS
// ========================================
model AnexoProcesso {
  id            Int      @id @default(autoincrement())
  nome          String   @db.VarChar(200)
  tipo          String   @db.VarChar(50)
  nomeArquivo   String   @db.VarChar(300)
  urlArquivo    String   @db.Text
  tamanho       Int?
  mimeType      String?  @db.VarChar(100)
  
  processoId    Int
  processo      Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())

  @@index([processoId])
}

model AnexoContratante {
  id            Int      @id @default(autoincrement())
  nome          String   @db.VarChar(200)
  tipo          String?  @db.VarChar(50)
  nomeArquivo   String   @db.VarChar(300)
  urlArquivo    String   @db.Text
  tamanho       Int?
  mimeType      String?  @db.VarChar(100)
  
  contratanteId Int
  contratante   Contratante @relation(fields: [contratanteId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())

  @@index([contratanteId])
}

model AnexoRequerente {
  id            Int      @id @default(autoincrement())
  nome          String   @db.VarChar(200)
  tipo          String?  @db.VarChar(50)
  nomeArquivo   String   @db.VarChar(300)
  urlArquivo    String   @db.Text
  tamanho       Int?
  mimeType      String?  @db.VarChar(100)
  
  requerenteId  Int
  requerente    Requerente @relation(fields: [requerenteId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())

  @@index([requerenteId])
}

// ========================================
// LOG DE AUDITORIA
// ========================================
model LogAuditoria {
  id          Int      @id @default(autoincrement())
  acao        String   @db.VarChar(50)
  entidade    String   @db.VarChar(50)
  entidadeId  Int?
  descricao   String   @db.Text
  detalhes    Json?
  
  usuarioId   Int?
  usuario     Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  
  criadoEm    DateTime @default(now())

  @@index([entidade])
  @@index([usuarioId])
  @@index([criadoEm])
}