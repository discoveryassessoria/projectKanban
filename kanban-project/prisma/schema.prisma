// ============================================================
// MOTOR — Fase 1A: Tipos de Processo (Processos de Nacionalidade)
// ============================================================
model TipoProcessoNacionalidade {
  id               Int      @id @default(autoincrement())
  code             String   @unique @db.VarChar(40)
  name             String   @db.VarChar(200)
  countryKey       String   @db.VarChar(40)
  countryLabel     String   @db.VarChar(80)
  nationalityKey   String   @db.VarChar(40)
  nationalityLabel String   @db.VarChar(80)
