  feePercent          Decimal? @db.Decimal(7, 4)
  fixedFee            Decimal? @db.Decimal(12, 2)
  anticipationEnabled Boolean  @default(false)
  anticipationPercent Decimal? @db.Decimal(7, 4)
  installmentsFrom    Int?
  installmentsTo      Int?
  criadoEm            DateTime @default(now())
